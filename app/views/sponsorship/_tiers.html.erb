<section>
  <div class="container">
    <div class="mb-16 reveal">
      <h2 class="heading heading-2">Sponsorship tiers.</h2>
      <p class="text-lg max-w-2xl">
        Each tier builds on the one before it. Pick the level that fits your goals and budget.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 items-start reveal stagger stamp" data-stagger-interval="150">
      <% @tiers.each_with_index do |tier, index| %>
        <div>
          <%= render Site::SponsorshipTierComponent.new(
                tier: tier,
                inherited_tiers: @tiers.take(index)
              ) %>
        </div>
      <% end %>
    </div>
  </div>
</section>
