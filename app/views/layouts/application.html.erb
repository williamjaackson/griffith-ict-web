<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= content_for(:title) || "Griffith ICT Club" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Griffith ICT Club">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="theme-color" content="#FAF7F2">
    <% if content_for?(:robots) %>
      <meta name="robots" content="<%= content_for(:robots) %>">
    <% end %>
    <% meta = Rails.application.config.meta %>
    <% canonical_url = "#{meta[:url]}#{request.path == '/' ? '' : request.path}" %>
    <meta name="description" content="<%= meta[:description] %>">
    <meta property="og:type" content="website">
    <meta property="og:site_name" content="<%= meta[:site_name] %>">
    <meta property="og:title" content="<%= meta[:site_name] %>">
    <meta property="og:description" content="<%= meta[:description] %>">
    <meta property="og:image" content="<%= meta[:url] %><%= meta[:og_image] %>">
    <meta property="og:url" content="<%= canonical_url %>">
    <meta name="twitter:card" content="summary_large_image">
    <link rel="canonical" href="<%= canonical_url %>">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&family=Unbounded:wght@400;600;700;800&display=swap" rel="stylesheet">

    <link rel="icon" href="/favicon.ico" sizes="any">
    <link rel="apple-touch-icon" href="/favicon.ico">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app %>
    <%= javascript_importmap_tags %>

    <% pr_number = ENV["PREVIEW_PR_NUMBER"].presence %>
    <% preview_env = pr_number ? :preview : (Rails.env.development? ? :development : nil) %>
  </head>

  <body class="min-h-screen flex flex-col <%= 'has-preview-banner' if preview_env %>" data-controller="animation modal">
    <% if preview_env %>
      <div id="preview-banner" data-controller="preview-banner">
        <% if preview_env == :preview %>
          <div>You are on a preview branch. Information may be outdated or incorrect.</div>
          <div><a href="<%= meta[:url] %>">Return to griffithict.club</a> · <a href="<%= Rails.application.config.socials[:github] %>pull/<%= pr_number %>" target="_blank" rel="noopener">View PR #<%= pr_number %></a></div>
        <% else %>
          <div>You are on a development branch. Information may be outdated or incorrect.</div>
          <div><a href="<%= meta[:url] %>">Return to griffithict.club</a></div>
        <% end %>
      </div>
    <% end %>
    <%= render Site::Navbar::Component.new %>
    <%= render Site::MembershipModalComponent.new %>

    <main class="flex-1 pt-20">
      <%= render Site::FlashComponent.new(flash: flash) %>
      <%= yield %>
    </main>

    <%= render Site::FooterComponent.new %>
  </body>
</html>
