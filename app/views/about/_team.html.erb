<section id="team" data-controller="tabs">
  <div class="container">
    <div class="mb-12 reveal">
      <h2 class="heading heading-2">Executive team.</h2>
      <p class="text-lg max-w-2xl">
        The people who keep things running. Our executive team is elected and appointed each year to lead the club across both campuses.
      </p>
    </div>

    <div class="flex gap-8 mb-10 border-b-3 border-brand-gray/20">
      <% @team.each_with_index do |campus, index| %>
        <button data-tabs-target="btn" data-action="tabs#select" data-index="<%= index %>"
                class="pb-3 text-sm font-bold cursor-pointer transition-colors -mb-[3px] heading <%= index.zero? ? 'text-brand-black border-b-3 border-brand-red' : 'border-b-3 border-transparent' %>">
          <%= campus["name"] %>
        </button>
      <% end %>
    </div>

    <% @team.each_with_index do |campus, index| %>
      <div data-tabs-target="panel" class="<%= "hidden" unless index.zero? %>">
        <%= render "about/team_group", campus: campus, members: campus["elected"], type: :elected if campus["elected"]&.any? %>
        <%= render "about/team_group", campus: campus, members: campus["appointed"], type: :appointed if campus["appointed"]&.any? %>
      </div>
    <% end %>
  </div>
</section>
