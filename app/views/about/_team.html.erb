<section id="team" data-controller="tabs role-modal">
  <div class="container">
    <div class="mb-12 reveal">
      <h2 class="heading heading-2">Executive team.</h2>
      <p class="text-lg max-w-2xl">
        The people who keep things running. Our executive team is elected and appointed each year to lead the club across both campuses.
      </p>
    </div>

    <%# Campus tabs %>
    <div class="flex gap-8 mb-10 border-b-3 border-brand-gray/20">
      <% @campuses.each_with_index do |campus, index| %>
        <button data-tabs-target="btn" data-action="tabs#select" data-index="<%= index %>"
                class="pb-3 text-sm font-bold cursor-pointer transition-colors duration-200 -mb-[3px] heading <%= index == 0 ? 'text-brand-black border-b-3 border-brand-red' : 'border-b-3 border-transparent' %>">
          <%= campus.fetch(:name) %>
        </button>
      <% end %>
    </div>

    <% @campuses.each_with_index do |campus, index| %>
      <div data-tabs-target="panel" class="<%= 'hidden' unless index == 0 %>">
        <%= render Site::Team::GroupComponent.new(
              members: campus.fetch(:elected, []),
              roles: @team_roles,
              type: :elected,
              separated: campus.fetch(:appointed, []).any?
            ) %>
        <%= render Site::Team::GroupComponent.new(
              members: campus.fetch(:appointed, []),
              roles: @team_roles,
              type: :appointed
            ) %>
      </div>
    <% end %>
  </div>

  <%= render Ui::ModalComponent.new(id: "role-modal", labelled_by: "role-modal-title", size: :large) do %>
    <span class="badge badge-sm mb-5">ROLE</span>
    <h2 id="role-modal-title" data-role-modal-target="title" class="heading heading-3"></h2>
    <p data-role-modal-target="member" class="font-semibold text-brand-red"></p>
    <ul data-role-modal-target="responsibilities" class="list-disc pl-5 space-y-3 mt-6"></ul>

    <div data-role-modal-target="applicationActions" class="hidden mt-8 pt-6 border-t-3 border-brand-cream"></div>

    <div class="mt-8 pt-6 border-t-3 border-brand-cream">
      <h3 class="heading heading-5">Role history</h3>
      <ol data-role-modal-target="timeline" class="ml-2 border-l-2 border-brand-gray/30"></ol>
    </div>
  <% end %>
</section>
