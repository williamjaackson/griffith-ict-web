<header>
  <div class="container enter stagger">
    <span class="badge -rotate-2 mb-8">ABOUT</span>
    <h1 class="heading heading-1">Meet <span class="heading-highlight">the club.</span></h1>
    <p class="text-lg md:text-xl max-w-2xl mb-10">
      Griffith ICT Club is Griffith University's student-run tech community. We run events, hackathons, and workshops across the Gold Coast and Brisbane campuses.
    </p>
    <div class="flex flex-wrap gap-4">
      <%= button_tag "Become a Member",
            type: "button",
            class: "btn btn-primary",
            data: Ui::ModalComponent.trigger_data(Site::MembershipModalComponent::ID) %>
      <a href="/" class="btn btn-secondary">Back to home</a>
    </div>
  </div>
</header>
