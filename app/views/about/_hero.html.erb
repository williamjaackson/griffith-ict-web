<header>
  <div class="container enter stagger">
    <%= render Ui::BadgeComponent.new(class: "-rotate-2 mb-8").with_content("About") %>
    <h1 class="heading heading-1">Meet <span class="heading-highlight">the club.</span></h1>
    <p class="text-lg md:text-xl max-w-2xl mb-10">
      Griffith ICT Club is Griffith University's student-run tech community. We run events, hackathons, and workshops across the Gold Coast and Brisbane campuses.
    </p>
    <div class="flex flex-wrap gap-4">
      <%= render Ui::ButtonComponent.new(data: { action: "dialog#open", dialog_id_param: "membership-dialog" }).with_content("Become a member") %>
      <%= render Ui::ButtonComponent.new(href: root_path, variant: :secondary).with_content("Back to home") %>
    </div>
  </div>
</header>
