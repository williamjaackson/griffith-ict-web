<% days_running = ((Time.current - Time.zone.at(site_meta[:established_at])) / 1.day).floor %>

<section>
  <div class="container">
    <div class="mb-16 reveal">
      <h2 class="heading heading-2">Since <span class="heading-highlight">day one.</span></h2>
      <p class="text-lg max-w-2xl">Established in 2025. We've been building, learning, and connecting ever since.</p>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-5 reveal stagger">
      <%= render Ui::CardComponent.new(tone: :red) do %>
        <span class="block text-4xl md:text-5xl font-extrabold heading"><%= number_with_delimiter(days_running) %></span>
        <span class="text-white/70 text-sm font-semibold">Days running</span>
      <% end %>
      <%= render Ui::CardComponent.new do %>
        <span class="block text-4xl md:text-5xl font-extrabold text-brand-black heading"><%= site_meta[:member_count] %></span>
        <span class="text-sm font-semibold">Members</span>
      <% end %>
      <%= render Ui::CardComponent.new(tone: :cream) do %>
        <span class="block text-4xl md:text-5xl font-extrabold text-brand-black heading">2</span>
        <span class="text-sm font-semibold">Campuses</span>
      <% end %>
      <%= render Ui::CardComponent.new do %>
        <span class="block text-4xl md:text-5xl font-extrabold text-brand-black heading">2025</span>
        <span class="text-sm font-semibold">Established</span>
      <% end %>
    </div>
  </div>
</section>
