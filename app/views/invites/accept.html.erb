<section class="px-6 py-24 md:py-32">
  <div class="max-w-md mx-auto">
    <div class="mb-8">
      <h1 class="heading heading-2">Create your <span class="heading-highlight">account.</span></h1>
      <p class="text-lg">
        You've been invited to join as <span class="font-semibold text-brand-black"><%= @invite.role %></span>.
      </p>
    </div>

    <%= render "shared/errors", errors: @errors if @errors %>

    <%= render Ui::CardComponent.new(shadow: :black, padding: :large) do %>
      <%= form_with url: complete_invite_path(token: @invite.token), method: :post, class: "space-y-5" do |form| %>
        <div>
          <span class="input-label">Email address</span>
          <input type="email" value="<%= @invite.email %>" disabled class="block w-full rounded-md border-2 border-brand-cream bg-brand-cream/50 px-3 py-2.5">
        </div>

        <div>
          <%= form.label :password, class: "input-label" %>
          <%= form.password_field :password, required: true, autocomplete: "new-password", placeholder: "Choose a password", minlength: 8, maxlength: 72, class: "input-field" %>
        </div>

        <div>
          <%= form.label :password_confirmation, "Confirm password", class: "input-label" %>
          <%= form.password_field :password_confirmation, required: true, autocomplete: "new-password", placeholder: "Confirm your password", minlength: 8, maxlength: 72, class: "input-field" %>
        </div>

        <div>
          <%= render Ui::ButtonComponent.new(type: :submit, class: "w-full").with_content("Create account") %>
        </div>
      <% end %>
    <% end %>
  </div>
</section>
