<div class="min-h-screen bg-brand-bg flex items-center justify-center px-4">
  <div class="w-full max-w-md">
    <div class="text-center mb-8">
      <h1 class="font-[Unbounded] font-bold text-3xl text-brand-black">Sign in</h1>
      <p class="text-brand-gray mt-2">Griffith ICT Club Staff</p>
    </div>

    <% if alert = flash[:alert] %>
      <p class="py-2 px-3 bg-brand-red-50 mb-5 text-brand-red font-medium rounded-lg" id="alert"><%= alert %></p>
    <% end %>

    <% if notice = flash[:notice] %>
      <p class="py-2 px-3 bg-green-50 mb-5 text-green-600 font-medium rounded-lg" id="notice"><%= notice %></p>
    <% end %>

    <div class="bg-white border-3 border-brand-black p-8 shadow-[6px_6px_0px_var(--color-brand-black)]">
      <%= form_with url: session_url, class: "space-y-5" do |form| %>
        <div>
          <label class="block text-sm font-semibold text-brand-black mb-1">Email address</label>
          <%= form.email_field :email_address, required: true, autofocus: true, autocomplete: "username", placeholder: "you@griffithict.club", value: params[:email_address], class: "block w-full rounded-md border-2 border-brand-cream bg-brand-bg focus:outline-none focus:border-brand-red px-3 py-2.5" %>
        </div>

        <div>
          <label class="block text-sm font-semibold text-brand-black mb-1">Password</label>
          <%= form.password_field :password, required: true, autocomplete: "current-password", placeholder: "Enter your password", maxlength: 72, class: "block w-full rounded-md border-2 border-brand-cream bg-brand-bg focus:outline-none focus:border-brand-red px-3 py-2.5" %>
        </div>

        <div>
          <%= form.submit "Sign in", class: "w-full inline-flex items-center justify-center text-center font-bold border-3 border-brand-black cursor-pointer transition-all duration-200 hover:-translate-y-1 active:translate-y-0 active:shadow-none bg-brand-red text-white px-8 py-3 text-base hover:shadow-[5px_5px_0px_var(--color-brand-black)]", style: "font-family: 'Unbounded', sans-serif; font-weight: 600;" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
