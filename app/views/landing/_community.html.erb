<% channels = [
  ["Discord", site_socials[:discord], "discord", "Our home base. Chat, ask questions, find teammates.", "bg-brand-discord"],
  ["GitHub", site_socials[:github], "github", "Open source projects, workshop code, and club infrastructure.", "bg-brand-black"],
  ["LinkedIn", site_socials[:linkedin], "linkedin", "Professional updates, event recaps, and job leads.", "bg-brand-linkedin"],
  ["Instagram", site_socials[:instagram], "instagram", "Event photos, reels, and behind-the-scenes content.", "bg-brand-red"]
] %>

<section id="community">
  <div class="container">
    <div class="mb-16 reveal">
      <h2 class="heading heading-2">Find us everywhere.</h2>
      <p class="text-lg max-w-2xl">Our Discord is the hub for everything. But we're also on the other platforms you use.</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
      <% channels.each do |name, href, icon_name, description, background| %>
        <%= link_to href, target: "_blank", rel: "noopener" do %>
          <%= render Ui::CardComponent.new(interactive: true, shadow: :black, class: "#{background} text-white") do %>
            <div class="flex items-start gap-5">
              <%= icon icon_name, library: "brands", class: "w-9 h-9 shrink-0" %>
              <div>
                <h3 class="heading heading-4 text-white"><%= name %></h3>
                <p class="text-white/70 text-sm"><%= description %></p>
              </div>
            </div>
          <% end %>
        <% end %>
      <% end %>
    </div>
  </div>
</section>
