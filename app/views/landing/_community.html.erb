<section id="community">
  <div class="container">
    <div class="mb-16 reveal">
      <h2 class="heading heading-2">Find us everywhere.</h2>
      <p class="text-lg max-w-2xl">
        Our Discord is the hub for everything. But we're also on the other platforms you use.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 reveal stagger">
      <a href="<%= Rails.application.config.socials[:discord] %>" target="_blank" rel="noopener" class="card card-link hover:shadow-[5px_5px_0px_var(--color-brand-discord)]" style="background-color: var(--color-brand-discord);">
        <div class="flex items-start gap-5">
          <div class="text-white shrink-0">
            <%= icon "discord", library: "brands", class: "w-9 h-9" %>
          </div>
          <div>
            <h3 class="heading heading-4 text-white">Discord</h3>
            <p class="text-white/70 text-sm">Our home base. Chat, ask questions, find teammates.</p>
          </div>
        </div>
      </a>

      <a href="<%= Rails.application.config.socials[:github] %>" target="_blank" rel="noopener" class="card card-link hover:shadow-[5px_5px_0px_var(--color-brand-black)]" style="background-color: var(--color-brand-black);">
        <div class="flex items-start gap-5">
          <div class="text-white shrink-0">
            <%= icon "github", library: "brands", class: "w-9 h-9" %>
          </div>
          <div>
            <h3 class="heading heading-4 text-white">GitHub</h3>
            <p class="text-white/70 text-sm">Open source projects, workshop code, and club infra.</p>
          </div>
        </div>
      </a>

      <a href="<%= Rails.application.config.socials[:linkedin] %>" target="_blank" rel="noopener" class="card card-link hover:shadow-[5px_5px_0px_var(--color-brand-linkedin)]" style="background-color: var(--color-brand-linkedin);">
        <div class="flex items-start gap-5">
          <div class="text-white shrink-0">
            <%= icon "linkedin", library: "brands", class: "w-9 h-9" %>
          </div>
          <div>
            <h3 class="heading heading-4 text-white">LinkedIn</h3>
            <p class="text-white/70 text-sm">Professional updates, event recaps, and job leads.</p>
          </div>
        </div>
      </a>

      <a href="<%= Rails.application.config.socials[:instagram] %>" target="_blank" rel="noopener" class="card card-link hover:shadow-[5px_5px_0px_var(--color-brand-red)]" style="background-color: var(--color-brand-red);">
        <div class="flex items-start gap-5">
          <div class="text-white shrink-0">
            <%= icon "instagram", library: "brands", class: "w-9 h-9" %>
          </div>
          <div>
            <h3 class="heading heading-4 text-white">Instagram</h3>
            <p class="text-white/70 text-sm">Event photos, reels, and behind-the-scenes content.</p>
          </div>
        </div>
      </a>
    </div>
  </div>
</section>
