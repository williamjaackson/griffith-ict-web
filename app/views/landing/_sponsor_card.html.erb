<% if local_assigns[:placeholder] %>
  <div class="flex items-center justify-center h-24 bg-white border-3 border-dashed border-brand-black/30 text-brand-gray/40 text-sm font-bold">Your logo here</div>
<% else %>
  <% tier_color = { "OPAL" => "var(--color-tier-opal)", "AMBER" => "var(--color-tier-amber)", "RUBY" => "var(--color-tier-ruby)" }.fetch(tier.upcase) %>
  <%= link_to website, target: "_blank", rel: "noopener", class: "group" do %>
    <%= render Ui::CardComponent.new(padding: :small, interactive: true, shadow: :red, class: "flex items-center justify-center") do %>
      <%= render Ui::BadgeComponent.new(size: :small, class: "absolute -top-3 -right-3 rotate-12", style: "background-color: #{tier_color}").with_content(tier) %>
      <%= image_tag logo, alt: name, class: "max-h-14 max-w-full object-contain" %>
      <%= render Ui::BadgeComponent.new(variant: :dark, size: :small, class: "absolute -bottom-4 left-1/2 -translate-x-1/2 whitespace-nowrap opacity-0 group-hover:opacity-100").with_content(name) %>
    <% end %>
  <% end %>
<% end %>
