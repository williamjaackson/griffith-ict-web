<header>
  <div class="container">
    <div class="grid grid-cols-1 lg:grid-cols-5 gap-8 lg:gap-8 items-center">
      <div class="lg:col-span-3 enter stagger">
        <h1><%= render Ui::BadgeComponent.new(class: "-rotate-2 mb-8").with_content("Griffith ICT Club") %></h1>
        <h2 class="heading heading-1">Build. Learn. <span class="heading-highlight">Connect.</span></h2>
        <p class="text-lg md:text-xl max-w-lg mb-10">
          Griffith University's IT club for computer science, information technology, cyber security, and software engineering. Join us on the Gold Coast or in Brisbane.
        </p>
        <div class="flex flex-wrap gap-4">
          <%= render Ui::ButtonComponent.new(data: { action: "dialog#open", dialog_id_param: "membership-dialog" }).with_content("Become a member") %>
          <%= render Ui::ButtonComponent.new(href: events_path, variant: :secondary).with_content("View events") %>
        </div>
      </div>

      <div class="lg:col-span-2 flex flex-col md:flex-row lg:flex-col gap-5 mt-8 md:mt-0 enter stagger stamp" data-stagger-interval="150" data-stagger-offset="200">
        <div>
          <%= render Ui::CardComponent.new(tone: :red, class: "rotate-1") do %>
            <span class="block text-4xl md:text-5xl font-extrabold text-white heading"><%= Rails.application.config.meta[:member_count] %></span>
            <span class="text-white/70 text-sm font-semibold">Members</span>
          <% end %>
        </div>

        <div>
          <%= render Ui::CardComponent.new(class: "-rotate-2 bg-brand-red-50") do %>
            <span class="block text-4xl md:text-5xl font-extrabold text-brand-black heading">Weekly</span>
            <span class="text-sm font-semibold">Events</span>
          <% end %>
        </div>

        <div>
          <%= render Ui::CardComponent.new(tone: :cream, class: "rotate-1") do %>
            <span class="block text-4xl md:text-5xl font-extrabold text-brand-black heading">2</span>
            <span class="text-sm font-semibold">Campuses</span>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</header>
