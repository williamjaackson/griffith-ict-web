<% sponsor_slots = [4 - @sponsors.size - 1, 0].max %>

<section id="sponsors">
  <div class="container">
    <div class="mb-16 reveal">
      <%= render Ui::BadgeComponent.new(class: "rotate-2 mb-4").with_content("Our partners") %>
      <h2 class="heading heading-2">Backed by industry.</h2>
      <p class="text-lg max-w-2xl">
        We partner with companies who believe in supporting the next generation of tech talent.
        Sponsors help us run bigger events, better hackathons, and provide real-world opportunities for our members.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-5 reveal">
      <% @sponsors.each do |sponsor| %>
        <%= render "landing/sponsor_card",
              name: sponsor.fetch("name"),
              tier: sponsor.fetch("tier"),
              logo: sponsor.fetch("logo"),
              website: sponsor.fetch("website") %>
      <% end %>

      <% sponsor_slots.times do %>
        <%= render "landing/sponsor_card", placeholder: true %>
      <% end %>

      <%= link_to sponsorship_path do %>
        <%= render Ui::CardComponent.new(tone: :red, padding: :small, shadow: :black, interactive: true, class: "grid place-items-center") do %>
          <p class="font-bold inline-flex items-center gap-1">Sponsor us <%= icon "arrow-right", class: "w-4 h-4" %></p>
        <% end %>
      <% end %>
    </div>

    <% if @perks.any? %>
      <div class="mt-16 reveal">
        <p class="text-base mb-6">
          Our <%= link_to "perks program", "#{sponsorship_path}#perks-program", class: "text-brand-red font-bold hover:underline" %>
          partners with companies and organisations that support our members.
        </p>

        <div class="grid grid-cols-[repeat(auto-fit,minmax(9rem,1fr))] gap-4">
          <% @perks.each do |perk| %>
            <% dialog_id = "perk-#{perk.fetch("name").parameterize}" %>
            <button type="button"
                    class="group flex items-center justify-center relative border-3 border-brand-black bg-white p-3 h-20 cursor-pointer transition-all hover:-translate-y-1 hover:shadow-[5px_5px_0px_var(--color-brand-red)]"
                    data-action="dialog#open" data-dialog-id-param="<%= dialog_id %>">
              <%= image_tag perk.fetch("logo"), alt: perk.fetch("name"), class: "max-h-10 max-w-full object-contain" %>
              <%= render Ui::BadgeComponent.new(variant: :dark, size: :small, class: "absolute -bottom-4 left-1/2 -translate-x-1/2 whitespace-nowrap opacity-0 group-hover:opacity-100").with_content(perk.fetch("name")) %>
            </button>

            <%= render Ui::DialogComponent.new(id: dialog_id, title: perk.fetch("name")) do %>
              <%= image_tag perk.fetch("icon"), alt: "", class: "max-h-16 max-w-2/3 object-contain mb-4" %>
              <p class="mb-6"><%= perk.fetch("description") %></p>
              <%= render Ui::ButtonComponent.new(href: perk.fetch("website"), target: "_blank", rel: "noopener").with_content("Visit website") %>
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</section>
