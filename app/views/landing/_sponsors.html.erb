<section id="sponsors" data-controller="perk-modal">
  <div class="container">
    <div class="mb-16 reveal">
      <span class="badge rotate-2 mb-4">OUR PARTNERS</span>
      <h2 class="heading heading-2">Backed by industry.</h2>
      <p class="text-lg max-w-2xl">
        We partner with companies who believe in supporting the next generation of tech talent.
        Sponsors help us run bigger events, better hackathons, and provide real-world opportunities for our members.
      </p>
    </div>

    <%= render Site::SponsorGridComponent.new(sponsors: @sponsors) %>
    <%= render Site::PerksGridComponent.new(perks: @perks) %>
  </div>

  <%# Kept at section level to avoid transformed ancestor clipping fixed positioning. %>
  <%= render Ui::ModalComponent.new(id: Site::PerksGridComponent::MODAL_ID, labelled_by: "perk-modal-title") do %>
    <img data-perk-modal-target="icon" alt="" class="max-h-16 max-w-2/3 object-contain mb-4">
    <h3 id="perk-modal-title" data-perk-modal-target="name" class="heading heading-3 mb-3"></h3>
    <p data-perk-modal-target="description" class="mb-6"></p>
    <a data-perk-modal-target="link" href="#" target="_blank" rel="noopener" class="btn btn-primary">
      Check it out
    </a>
  <% end %>
</section>
