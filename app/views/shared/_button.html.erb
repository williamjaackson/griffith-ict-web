<%
  base_classes = "inline-block font-bold border-brand-black transition-all duration-200"

  variant_classes = case variant
  when :primary
    "bg-brand-red text-white"
  when :secondary
    "bg-white text-brand-black"
  end

  size_classes = case size
  when :base
    "px-8 py-4 text-base border-3 hover:translate-x-1 hover:-translate-y-1"
  when :sm
    "px-5 py-2.5 text-sm border-2 hover:translate-x-0.5 hover:-translate-y-0.5"
  end

  shadow_classes = {
    [:primary, :base]   => "hover:shadow-[5px_5px_0px_#222222]",
    [:primary, :sm]     => "hover:shadow-[4px_4px_0px_#222222]",
    [:secondary, :base] => "hover:shadow-[5px_5px_0px_#D32F2F]",
    [:secondary, :sm]   => "hover:shadow-[4px_4px_0px_#D32F2F]",
  }

  classes = [base_classes, variant_classes, size_classes, shadow_classes[[variant, size]], options.delete(:class)].compact.join(" ")
%>
<%= link_to label, href, class: classes, style: "font-family: 'Unbounded', sans-serif; font-weight: 600;", **options %>
