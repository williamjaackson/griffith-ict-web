<%
  base_classes = "inline-flex items-center justify-center text-center font-bold border-3 border-brand-black transition-all duration-200"

  variant_classes = case variant
  when :primary
    "bg-brand-red text-white"
  when :secondary
    "bg-white text-brand-black"
  end

  size_classes = case size
  when :base
    "px-8 py-4 text-base hover:-translate-y-1"
  when :sm
    "px-5 py-2.5 text-sm hover:-translate-y-1"
  end

  shadow_class = case variant
  when :primary
    "hover:shadow-[5px_5px_0px_var(--color-brand-black)]"
  when :secondary
    "hover:shadow-[5px_5px_0px_var(--color-brand-red)]"
  end

  classes = [base_classes, variant_classes, size_classes, shadow_class, options.delete(:class)].compact.join(" ")
%>
<%= link_to label, href, class: classes, style: "font-family: 'Unbounded', sans-serif; font-weight: 600;", **options %>
