<div class="max-w-lg mx-auto px-4 py-12">
  <h1 class="heading heading-2 mb-8">New invite</h1>

  <% if @invite.errors.any? %>
    <div role="alert" class="py-2 px-3 bg-brand-red-50 mb-5 text-brand-red font-medium rounded-lg">
      <% @invite.errors.full_messages.each do |message| %>
        <p><%= message %></p>
      <% end %>
    </div>
  <% end %>

  <div class="bg-white border-3 border-brand-black p-8 shadow-[6px_6px_0px_var(--color-brand-black)]">
    <%= form_with model: [:admin, @invite], class: "space-y-5" do |form| %>
      <div>
        <%= form.label :email, "Email address", class: "input-label" %>
        <%= form.email_field :email, required: true, autofocus: true, placeholder: "name@example.com", class: "input-field" %>
      </div>

      <div>
        <%= form.label :role, class: "input-label" %>
        <%= form.select :role,
              Invite.roles.keys.map { |role| [role.humanize, role] },
              { selected: @invite.role || "exec" },
              class: "input-field" %>
      </div>

      <div class="flex items-center gap-3">
        <button type="submit" class="btn btn-primary btn-sm">Create invite</button>
        <%= link_to "Cancel", admin_invites_path, class: "text-sm font-semibold hover:text-brand-black" %>
      </div>
    <% end %>
  </div>
</div>
