<div class="max-w-lg mx-auto px-4 py-12">
  <h1 class="heading heading-2 mb-8">New invite</h1>
  <%= render "shared/errors", errors: @invite.errors %>

  <%= render Ui::CardComponent.new(shadow: :black, padding: :large) do %>
    <%= form_with model: [:admin, @invite], class: "space-y-5" do |form| %>
      <div>
        <%= form.label :email, "Email address", class: "input-label" %>
        <%= form.email_field :email, required: true, autofocus: true, placeholder: "name@example.com", class: "input-field" %>
      </div>

      <div>
        <%= form.label :role, class: "input-label" %>
        <%= form.select :role, Invite.roles.keys.map { |role| [role.humanize, role] }, {}, class: "input-field" %>
      </div>

      <div class="flex items-center gap-3">
        <%= render Ui::ButtonComponent.new(type: :submit, size: :small).with_content("Create invite") %>
        <%= render Ui::ButtonComponent.new(href: admin_invites_path, variant: :quiet, size: :small).with_content("Cancel") %>
      </div>
    <% end %>
  <% end %>
</div>
