<div class="max-w-4xl mx-auto px-4 py-12">
  <div class="flex items-center justify-between mb-8">
    <h2 class="heading">Invites</h2>
    <a href="<%= new_admin_invite_path %>" class="btn btn-primary btn-sm">New invite</a>
  </div>

  <% if @invites.any? %>
    <div class="space-y-3">
      <% @invites.each do |invite| %>
        <div class="bg-white border-3 border-brand-black p-5 flex items-center justify-between" data-controller="clipboard" data-clipboard-text-value="<%= accept_invite_url(token: invite.token) %>">
          <div>
            <p class="font-semibold text-brand-black"><%= invite.email %></p>
            <p class="text-sm">
              <%= invite.role.capitalize %> ·
              Invited by <%= invite.invited_by.email_address %> ·
              <% if invite.accepted? %>
                <span class="text-green-600">Accepted</span>
              <% elsif invite.expired? %>
                <span class="text-brand-red">Expired</span>
              <% else %>
                Expires <%= time_ago_in_words(invite.expires_at) %> from now
              <% end %>
            </p>
          </div>

          <% unless invite.accepted? %>
            <div class="flex items-center gap-2">
              <% unless invite.expired? %>
                <button data-action="clipboard#copy" class="text-sm font-semibold text-brand-black border-2 border-brand-black px-3 py-1.5 cursor-pointer hover:bg-brand-cream transition-colors">
                  Copy link
                </button>
              <% end %>

              <%= button_to "Revoke", admin_invite_path(invite), method: :delete, class: "text-sm font-semibold text-brand-red border-2 border-brand-red px-3 py-1.5 cursor-pointer hover:bg-brand-red-50 transition-colors", data: { turbo_confirm: "Revoke this invite?" } %>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="">No invites yet.</p>
  <% end %>
</div>
