<div class="max-w-4xl mx-auto px-4 py-12">
  <div class="flex items-center justify-between mb-8">
    <h1 class="heading heading-2">Invites</h1>
    <%= render Ui::ButtonComponent.new(href: new_admin_invite_path, size: :small).with_content("New invite") %>
  </div>

  <% if @invites.any? %>
    <div class="space-y-3">
      <% @invites.each do |invite| %>
        <div class="bg-white border-3 border-brand-black p-5 flex items-center justify-between" data-controller="clipboard" data-clipboard-text-value="<%= accept_invite_url(token: invite.token) %>">
          <div>
            <p class="font-semibold text-brand-black"><%= invite.email %></p>
            <p class="text-sm">
              <%= invite.role.capitalize %> ·
              Invited by <%= invite.invited_by.email_address %> ·
              <% if invite.accepted? %>
                <span class="text-green-600">Accepted</span>
              <% elsif invite.expired? %>
                <span class="text-brand-red">Expired</span>
              <% else %>
                Expires <%= time_ago_in_words(invite.expires_at) %> from now
              <% end %>
            </p>
          </div>

          <% unless invite.accepted? %>
            <div class="flex items-center gap-2">
              <% unless invite.expired? %>
                <%= render Ui::ButtonComponent.new(variant: :quiet, size: :small, data: { action: "clipboard#copy" }).with_content("Copy link") %>
              <% end %>

              <%= form_with url: admin_invite_path(invite), method: :delete do %>
                <%= render Ui::ButtonComponent.new(variant: :danger, size: :small, type: :submit).with_content("Revoke") %>
              <% end %>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  <% else %>
    <p>No invites yet.</p>
  <% end %>
</div>
