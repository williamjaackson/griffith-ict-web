<% content_for(:title, "Events | Griffith ICT Club") %>
<% content_for(:meta_description, "Discover upcoming and past Griffith ICT Club hackathons, workshops, social events, and industry events.") %>
<% content_for(:canonical_url, "#{Rails.application.config.meta[:url]}#{events_path}") %>

<header>
  <div class="container enter stagger">
    <span class="badge -rotate-2 mb-8">EVENTS</span>
    <h1 class="heading heading-1">What's <span class="heading-highlight">on.</span></h1>
    <p class="text-lg md:text-xl max-w-2xl">
      Build things, meet people, and learn something useful. Browse what's coming up and look back at what we've run.
    </p>
  </div>
</header>

<section id="upcoming">
  <div class="container">
    <div class="mb-12 reveal">
      <span class="badge badge-dark -rotate-1 mb-6">NEXT UP</span>
      <h2 class="heading heading-2">Upcoming events.</h2>
      <p class="text-lg max-w-2xl">Save the date and bring your best ideas.</p>
    </div>

    <% if @upcoming_events.any? %>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 reveal stagger">
        <% @upcoming_events.each do |event| %>
          <%= render "events/card", event: event %>
        <% end %>
      </div>
    <% else %>
      <div class="card max-w-2xl reveal">
        <h3 class="heading heading-4">More events coming soon.</h3>
        <p>Follow our community channels to hear about the next one first.</p>
      </div>
    <% end %>
  </div>
</section>

<%= render "events/event_types" %>

<section id="past">
  <div class="container">
    <div class="mb-12 reveal">
      <span class="badge -rotate-1 mb-6">ARCHIVE</span>
      <h2 class="heading heading-2">Past events.</h2>
      <p class="text-lg max-w-2xl">The ideas, workshops, and good times that got us here.</p>
    </div>

    <% if @past_events.any? %>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 reveal stagger">
        <% @past_events.each do |event| %>
          <%= render "events/card", event: event %>
        <% end %>
      </div>
    <% else %>
      <div class="card max-w-2xl reveal">
        <h3 class="heading heading-4">The archive starts here.</h3>
        <p>Completed events will move into this section automatically.</p>
      </div>
    <% end %>
  </div>
</section>
