<% content_for(:title, "#{@event.title} | Griffith ICT Club") %>
<% content_for(:meta_description, @event.summary) %>
<% content_for(:meta_image, event_absolute_asset_url(@event)) %>
<% content_for(:canonical_url, "#{Rails.application.config.meta[:url]}#{event_path(@event.slug)}") %>
<% content_for(:og_type, "event") %>
<% content_for :head do %>
  <script type="application/ld+json"><%= raw(json_escape(event_json_ld(@event).to_json)) %></script>
<% end %>

<header>
  <div class="container">
    <%= link_to events_path, class: "inline-flex items-center gap-2 font-bold text-brand-black hover:text-brand-red mb-10 transition-colors" do %>
      <%= icon("arrow-left", class: "w-4 h-4") %> All events
    <% end %>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-center">
      <div class="enter stagger">
        <span class="badge -rotate-2 mb-8"><%= event_status_label(@event) %></span>
        <h1 class="heading heading-2 md:!text-6xl"><%= @event.title %></h1>
        <p class="text-lg md:text-xl max-w-2xl mb-10"><%= @event.summary %></p>

        <div class="flex flex-wrap gap-4">
          <% if @event.rsvp_open? %>
            <%= link_to "RSVP now", "#rsvp", class: "btn btn-primary" %>
          <% end %>
          <% if @event.ticket_state == "available" %>
            <%= link_to event_ticket_label(@event), @event.admission.fetch("url"), class: "btn btn-primary", target: "_blank", rel: "noopener" %>
          <% else %>
            <span class="btn btn-disabled" aria-disabled="true"><%= event_ticket_label(@event) %></span>
          <% end %>
          <div>
            <button class="btn btn-secondary" onclick="window.dispatchEvent(new CustomEvent('membership-modal:open'))">Become a member</button>
            <p class="mt-2 text-xs font-extrabold tracking-wider text-brand-black">MEMBERSHIP IS REQUIRED.</p>
          </div>
        </div>
      </div>

      <div class="enter stamp" data-stagger-offset="200">
        <div class="border-3 border-brand-black bg-white rotate-1" style="box-shadow: 8px 8px 0px var(--color-brand-red);">
          <%= image_tag @event.image, alt: @event.image_alt, loading: "eager", fetchpriority: "high", class: "w-full h-auto" %>
        </div>
      </div>
    </div>
  </div>
</header>

<section>
  <div class="container">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 reveal stagger">
      <% [
        ["calendar-days", "Date", event_date(@event)],
        ["clock", "Time", event_time(@event)],
        ["map-pin", "Location", event_location(@event)],
        ["ticket", "Admission", event_price(@event)]
      ].each do |icon_name, label, value| %>
        <div class="card" style="box-shadow: 4px 4px 0px var(--color-brand-red-300);">
          <%= icon(icon_name, class: "w-7 h-7 text-brand-red mb-4") %>
          <p class="text-xs uppercase font-bold tracking-wider mb-1"><%= label %></p>
          <p class="heading font-bold text-brand-black"><%= value %></p>
        </div>
      <% end %>
    </div>

    <% if @event.admission.fetch("members_only") %>
      <div class="mt-8 p-5 border-3 border-brand-black bg-brand-red-50 reveal">
        <p class="font-bold text-brand-black">This event is for Griffith ICT Club members only. Membership is free and only takes a moment.</p>
      </div>
    <% end %>
  </div>
</section>

<section>
  <div class="container grid grid-cols-1 lg:grid-cols-5 gap-12 lg:gap-20">
    <div class="lg:col-span-3 reveal">
      <span class="badge badge-dark -rotate-1 mb-6">THE CHALLENGE</span>
      <h2 class="heading heading-2">Nothing useful.</h2>
      <div class="space-y-5 text-lg">
        <% @event.description.each do |paragraph| %>
          <p><%= paragraph %></p>
        <% end %>
      </div>
    </div>

    <div class="lg:col-span-2 reveal stagger">
      <div class="card" style="box-shadow: 6px 6px 0px var(--color-brand-red);">
        <%= icon("users", class: "w-8 h-8 text-brand-red mb-4") %>
        <h3 class="heading heading-4">Teams</h3>
        <p class="text-lg font-bold text-brand-black"><%= @event.details.fetch("team_size") %></p>
      </div>
      <% @event.details.fetch("inclusions").each do |inclusion| %>
        <div class="flex items-center gap-3 border-3 border-brand-black bg-white p-4 mt-4">
          <%= icon("check", class: "w-5 h-5 text-brand-red shrink-0") %>
          <span class="font-bold text-brand-black"><%= inclusion %></span>
        </div>
      <% end %>
    </div>
  </div>
</section>

<section>
  <div class="container">
    <div class="mb-12 reveal">
      <span class="badge -rotate-1 mb-6">PRIZES</span>
      <h2 class="heading heading-2">Build weird. Win big.</h2>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 reveal stagger stamp">
      <% @event.prizes.each do |prize| %>
        <div class="card text-center" style="box-shadow: 6px 6px 0px var(--color-brand-red);">
          <%= icon("trophy", class: "w-10 h-10 text-brand-red mx-auto mb-5") %>
          <p class="heading text-sm font-bold uppercase mb-2"><%= prize.fetch("place") %></p>
          <p class="heading text-3xl font-extrabold text-brand-black"><%= prize.fetch("award") %></p>
        </div>
      <% end %>
    </div>
  </div>
</section>

<% if @event.rsvp_open? %>
  <section id="rsvp">
    <div class="container max-w-4xl">
      <div class="reveal">
        <span class="badge -rotate-1 mb-6">RSVP</span>
        <h2 class="heading heading-2">Save your spot.</h2>
        <p class="text-lg max-w-2xl mb-3">Event details will be sent to your Griffith student email.</p>
        <p class="font-bold text-brand-black mb-8">Double-check that your student number is correct before submitting.</p>

        <div class="card" style="box-shadow: 6px 6px 0px var(--color-brand-red);">
          <% if @rsvp.errors.any? %>
            <div class="p-4 bg-brand-red-50 border-2 border-brand-red mb-6 text-brand-red font-semibold" role="alert">
              <p class="font-extrabold mb-2">Please check your RSVP:</p>
              <ul class="list-disc pl-5 space-y-1">
                <% @rsvp.errors.full_messages.each do |message| %>
                  <li><%= message %></li>
                <% end %>
              </ul>
            </div>
          <% end %>

          <%= form_with model: @rsvp, url: event_rsvp_path(@event.slug), class: "space-y-5" do |form| %>
            <div>
              <%= form.label :full_name, "Full name", class: "input-label" %>
              <%= form.text_field :full_name, required: true, autocomplete: "name", maxlength: 120, class: "input-field" %>
            </div>

            <div>
              <%= form.label :student_email, "Griffith student email", class: "input-label" %>
              <%= form.email_field :student_email, required: true, autocomplete: "email", placeholder: "preferred.name@griffithuni.edu.au", class: "input-field" %>
            </div>

            <div>
              <%= form.label :student_number, "Griffith student number", class: "input-label" %>
              <%= form.text_field :student_number, required: true, inputmode: "text", pattern: "[sS][0-9]{6,8}", placeholder: "s1234567", aria: { describedby: "student-number-help" }, class: "input-field" %>
              <p id="student-number-help" class="mt-2 text-sm">Use your Griffith sNumber: the letter “s” followed by 6–8 digits.</p>
            </div>

            <%= form.submit "Record my RSVP", class: "btn btn-primary cursor-pointer" %>
            <p class="text-sm">This form records your RSVP only. It does not send an automated email.</p>
          <% end %>
        </div>
      </div>
    </div>
  </section>
<% end %>

<section id="terms">
  <div class="container max-w-4xl">
    <div class="reveal">
      <span class="badge badge-dark rotate-1 mb-6">THE FINE PRINT</span>
      <h2 class="heading heading-2">Terms &amp; conditions.</h2>
      <% if @event.terms.fetch("state") == "published" %>
        <ol class="space-y-4 list-decimal pl-6 text-lg">
          <% @event.terms.fetch("items").each do |term| %>
            <li class="pl-2"><%= term %></li>
          <% end %>
        </ol>
      <% else %>
        <div class="card mt-8" style="box-shadow: 5px 5px 0px var(--color-brand-red-300);">
          <h3 class="heading heading-4">Coming soon.</h3>
          <p>Reviewed event terms will be published here before tickets become available.</p>
        </div>
      <% end %>
    </div>
  </div>
</section>
