<%= render Ui::DialogComponent.new(id: "event-rsvp-dialog", title: "RSVP for #{event.title}", open: rsvp.errors.any?) do %>
  <p class="mb-6">Reserve your place now. Membership is required.</p>
  <%= render "shared/errors", errors: rsvp.errors, heading: "Please check your RSVP" %>

  <%= form_with model: rsvp, url: event_rsvp_path(event.slug), class: "space-y-5" do |form| %>
    <div>
      <%= form.label :full_name, "Full name", class: "input-label" %>
      <%= form.text_field :full_name, required: true, autocomplete: "name", maxlength: 120, class: "input-field" %>
    </div>

    <div>
      <%= form.label :student_number, "Student number", class: "input-label" %>
      <%= form.text_field :student_number,
            required: true,
            inputmode: "text",
            pattern: "[sS][0-9]{7}",
            placeholder: "s1234567",
            autocomplete: "off",
            class: "input-field" %>
      <p class="mt-3 text-sm">We use your Griffith email derived from your student number.</p>
    </div>

    <div class="flex items-start gap-3">
      <%= form.check_box :membership_confirmed, required: true, class: "mt-1 h-5 w-5 accent-brand-red shrink-0" %>
      <div class="text-sm">
        <%= form.label :membership_confirmed, "I am a member of the Griffith ICT Club.", class: "font-bold text-brand-black" %>
        <button type="button" class="block mt-1 text-brand-red font-bold underline cursor-pointer"
                data-action="dialog#open" data-dialog-id-param="membership-dialog">Become a member</button>
      </div>
    </div>

    <div class="flex flex-wrap gap-3 pt-2">
      <%= render Ui::ButtonComponent.new(type: :submit).with_content("Record my RSVP") %>
      <%= render Ui::ButtonComponent.new(variant: :secondary, data: { action: "dialog#close" }).with_content("Cancel") %>
    </div>
  <% end %>
<% end %>
