<section id="event-types">
  <div class="container">
    <div class="mb-16 reveal">
      <span class="badge badge-dark rotate-1 mb-6">WHAT WE RUN</span>
      <h2 class="heading heading-2">Something for everyone.</h2>
      <p class="text-lg max-w-2xl">From relaxed social nights to ambitious builds, there's always a reason to get involved.</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 reveal stagger">
      <% [
        ["smile", "Social Events", "Game nights, BBQs, trivia, and casual hangouts. The best part of uni is the people, and we make sure you meet them.", "var(--color-brand-red-300)"],
        ["briefcase", "Industry Events", "Connect with companies hiring grads. Hear from engineers, ask questions, and get your foot in the door early.", "var(--color-brand-red-dark)"],
        ["trophy", "Hackathons", "Team up, ship fast, win prizes. We design and run our own hackathons that everyone can participate in.", "var(--color-brand-red)"],
        ["code", "Workshops", "Hands-on sessions covering web dev, cloud, AI, cybersecurity, and more. Learn by building real things.", "var(--color-brand-red-200)"]
      ].each do |icon_name, title, description, shadow| %>
        <div class="card" style="box-shadow: 5px 5px 0px <%= shadow %>;">
          <div class="w-10 h-10 bg-brand-red/10 flex items-center justify-center mb-4">
            <%= icon(icon_name, class: "w-5 h-5 text-brand-red") %>
          </div>
          <h3 class="heading heading-4"><%= title %></h3>
          <p class="text-sm"><%= description %></p>
        </div>
      <% end %>
    </div>
  </div>
</section>
