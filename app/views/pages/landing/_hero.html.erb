<header class="px-6 pt-8 pb-24">
  <div class="max-w-6xl mx-auto w-full">
    <div class="grid grid-cols-1 lg:grid-cols-5 gap-8 lg:gap-8 items-center">
      <div class="lg:col-span-3">
        <div class="animate-hero-in">
          <%= ui_badge("GRIFFITH ICT CLUB", class: "-rotate-2 mb-8") %>
        </div>

        <div class="animate-hero-in" style="animation-delay: 100ms;">
          <%= ui_heading("Build. Learn. Connect.", level: 1, highlight: "Connect.") %>
        </div>

        <p class="animate-hero-in text-brand-gray text-lg md:text-xl max-w-lg leading-relaxed mb-10" style="animation-delay: 200ms;">
          The student community where you'll find your people. You're a professional or know nothing at all? It doesn't matter. Come learn new skills, meet like-minded peers, and get ahead.
        </p>

        <div class="animate-hero-in flex flex-wrap gap-4" style="animation-delay: 300ms;">
          <%= ui_button("Join our Discord", href: "#community", variant: :primary) %>
          <%= ui_button("Learn more", href: "#about", variant: :secondary) %>
        </div>
      </div>

      <div class="lg:col-span-2 flex flex-col md:flex-row lg:flex-col gap-5 mt-8 md:mt-0">
        <div class="animate-hero-stamp" style="animation-delay: 200ms;">
          <%= ui_card(color: "var(--color-brand-red)", class: "rotate-1") do %>
            <span class="block text-4xl md:text-5xl font-extrabold text-white" style="font-family: 'Unbounded', sans-serif;">400+</span>
            <span class="text-white/70 text-sm font-semibold">Members</span>
          <% end %>
        </div>

        <div class="animate-hero-stamp" style="animation-delay: 350ms;">
          <%= ui_card(color: "var(--color-brand-red-50)", class: "-rotate-2") do %>
            <span class="block text-4xl md:text-5xl font-extrabold text-brand-black" style="font-family: 'Unbounded', sans-serif;">Weekly</span>
            <span class="text-brand-gray text-sm font-semibold">Events</span>
          <% end %>
        </div>

        <div class="animate-hero-stamp" style="animation-delay: 500ms;">
          <%= ui_card(color: "var(--color-brand-cream)", class: "rotate-1") do %>
            <span class="block text-4xl md:text-5xl font-extrabold text-brand-black" style="font-family: 'Unbounded', sans-serif;">2</span>
            <span class="text-brand-gray text-sm font-semibold">Campuses</span>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</header>
