<section id="sponsors" class="py-24 md:py-32 px-6 border-t-3 border-brand-black bg-brand-cream">
  <div class="max-w-6xl mx-auto">
    <div class="mb-16">
      <%= ui_badge("OUR PARTNERS", class: "rotate-2 mb-4") %>
      <%= ui_heading("Backed by industry.", level: 2) %>
      <p class="text-brand-gray text-lg max-w-2xl leading-relaxed">
        We partner with companies who believe in supporting the next generation of tech talent.
        Sponsors help us run bigger events, better hackathons, and provide real-world opportunities for our members.
      </p>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-5">
      <%= ui_card(class: "flex items-center justify-center !p-4 h-24", href: "https://www.parklandsbeachvolleyball.com/") do %>
        <span class="absolute -right-8 top-3 rotate-45 bg-tier-opal text-white text-[10px] font-bold px-8 py-0.5 border-y-2 border-brand-black" style="font-family: 'Unbounded', sans-serif;">OPAL</span>
        <%= image_tag "/sponsors/parklands.png", alt: "Parklands Beach Volleyball", class: "max-h-full max-w-full object-contain" %>
      <% end %>
      <div class="flex items-center justify-center h-24 bg-white border-3 border-dashed border-brand-black/30 text-brand-gray/40 text-sm font-bold">Your logo here</div>
      <div class="flex items-center justify-center h-24 bg-white border-3 border-dashed border-brand-black/30 text-brand-gray/40 text-sm font-bold">Your logo here</div>
      <%= ui_card(color: "var(--color-brand-red)", class: "grid place-items-center h-24", href: "/sponsorship") do %>
        <p class="text-white font-bold">Sponsor Us &rarr;</p>
      <% end %>
    </div>
  </div>
</section>
