        <div class="grid grid-cols-3 gap-6">
          <div class="text-center">
            <span class="block text-4xl md:text-5xl text-inst-navy mb-1" style="font-family: 'Source Serif 4', serif; font-weight: 700;">200+</span>
            <span class="text-inst-gray text-sm" style="font-family: 'Inter', sans-serif;">Members</span>
            <div class="w-full h-px bg-inst-accent/30 mt-3"></div>
          </div>
          <div class="text-center">
            <span class="block text-4xl md:text-5xl text-inst-navy mb-1" style="font-family: 'Source Serif 4', serif; font-weight: 700;">50+</span>
            <span class="text-inst-gray text-sm" style="font-family: 'Inter', sans-serif;">Events / yr</span>
