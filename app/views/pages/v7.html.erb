        <div class="md:col-span-4">
          <p class="text-inst-gray text-sm leading-relaxed" style="font-family: 'Inter', sans-serif;">
            From your first commit to opening a pull request. All levels welcome.
          </p>
        </div>
        <div class="md:col-span-2 text-inst-gray text-sm" style="font-family: 'Inter', sans-serif;">
          Nathan, N44
        </div>
      </div>

      <%# Event 2 %>
      <div class="reveal grid grid-cols-1 md:grid-cols-12 gap-2 md:gap-4 px-6 py-5 border-b border-inst-border hover:bg-inst-light/50 transition-colors">
        <div class="md:col-span-2">
          <span class="text-inst-navy font-semibold text-sm" style="font-family: 'Inter', sans-serif;">19 Mar 2026</span>
          <span class="block text-inst-gray text-xs md:hidden" style="font-family: 'Inter', sans-serif;">12:00 PM</span>
        </div>
        <div class="md:col-span-3">
          <span class="text-inst-navy font-semibold text-sm" style="font-family: 'Source Serif 4', serif; font-weight: 600;">Welcome Week BBQ</span>
        </div>
        <div class="md:col-span-1">
          <span class="inline-block bg-emerald-50 text-emerald-700 text-xs font-medium px-2 py-0.5 rounded" style="font-family: 'Inter', sans-serif;">Social</span>
        </div>
        <div class="md:col-span-4">
          <p class="text-inst-gray text-sm leading-relaxed" style="font-family: 'Inter', sans-serif;">
            Free food, lawn games, and good vibes. Bring your mates or come solo.
          </p>
        </div>
        <div class="md:col-span-2 text-inst-gray text-sm" style="font-family: 'Inter', sans-serif;">
          Gold Coast, G40
        </div>
      </div>

      <%# Event 3 %>
      <div class="reveal grid grid-cols-1 md:grid-cols-12 gap-2 md:gap-4 px-6 py-5 hover:bg-inst-light/50 transition-colors">
        <div class="md:col-span-2">
          <span class="text-inst-navy font-semibold text-sm" style="font-family: 'Inter', sans-serif;">02 Apr 2026</span>
          <span class="block text-inst-gray text-xs md:hidden" style="font-family: 'Inter', sans-serif;">9:00 AM</span>
        </div>
        <div class="md:col-span-3">
          <span class="text-inst-navy font-semibold text-sm" style="font-family: 'Source Serif 4', serif; font-weight: 600;">GIC Hack Day 2026</span>
        </div>
        <div class="md:col-span-1">
          <span class="inline-block bg-violet-50 text-violet-700 text-xs font-medium px-2 py-0.5 rounded" style="font-family: 'Inter', sans-serif;">Hackathon</span>
        </div>
        <div class="md:col-span-4">
          <p class="text-inst-gray text-sm leading-relaxed" style="font-family: 'Inter', sans-serif;">
            24 hours. One idea. Ship something awesome. Teams of 2–4, all skill levels.
          </p>
        </div>
        <div class="md:col-span-2 text-inst-gray text-sm" style="font-family: 'Inter', sans-serif;">
          Nathan, N78
        </div>
      </div>
    </div>

    <div class="reveal mt-8">
      <a href="#community" class="inline-flex items-center gap-2 text-inst-navy hover:text-inst-accent font-medium text-sm transition-colors" style="font-family: 'Inter', sans-serif;">
