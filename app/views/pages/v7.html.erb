<%# ═══════════════════════════════════════════════════════════
    ABOUT — Clean grid with left label
    ═══════════════════════════════════════════════════════════ %>
<section id="about" class="py-20 md:py-28 px-6">
  <div class="max-w-6xl mx-auto">
    <div class="reveal grid grid-cols-1 lg:grid-cols-4 gap-8 mb-16">
      <div>
        <span class="text-inst-accent font-semibold text-xs tracking-wider uppercase" style="font-family: 'Inter', sans-serif;">About</span>
      </div>
      <div class="lg:col-span-3">
        <h2 class="text-3xl md:text-4xl text-inst-navy mb-4" style="font-family: 'Source Serif 4', serif; font-weight: 700;">By students, for students.</h2>
        <p class="text-inst-gray text-lg leading-relaxed max-w-2xl" style="font-family: 'Inter', sans-serif;">
          GIC is Griffith University's ICT club, based across Nathan (Brisbane / Meanjin)
          and Gold Coast (Yugambeh) campuses. We exist to help students build skills,
          make friends, and kickstart their careers in technology.
        </p>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-px bg-inst-border">
      <div class="reveal bg-inst-bg p-8 md:p-10">
        <div class="flex items-start gap-4">
          <div class="w-10 h-10 bg-inst-accent/10 rounded-lg flex items-center justify-center text-inst-accent shrink-0">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
          </div>
          <div>
            <h3 class="text-inst-navy font-semibold text-base mb-1" style="font-family: 'Source Serif 4', serif; font-weight: 700;">Workshops</h3>
            <p class="text-inst-gray text-sm leading-relaxed" style="font-family: 'Inter', sans-serif;">
              Hands-on sessions covering web development, cloud computing, AI, cybersecurity, and more.
            </p>
          </div>
        </div>
      </div>

      <div class="reveal bg-inst-bg p-8 md:p-10">
        <div class="flex items-start gap-4">
          <div class="w-10 h-10 bg-inst-accent/10 rounded-lg flex items-center justify-center text-inst-accent shrink-0">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
          </div>
          <div>
            <h3 class="text-inst-navy font-semibold text-base mb-1" style="font-family: 'Source Serif 4', serif; font-weight: 700;">Hackathons</h3>
            <p class="text-inst-gray text-sm leading-relaxed" style="font-family: 'Inter', sans-serif;">
              Competitive team events where students build and ship projects in 24 hours. Local and national.
            </p>
          </div>
        </div>
      </div>

      <div class="reveal bg-inst-bg p-8 md:p-10">
        <div class="flex items-start gap-4">
          <div class="w-10 h-10 bg-inst-accent/10 rounded-lg flex items-center justify-center text-inst-accent shrink-0">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
          </div>
          <div>
            <h3 class="text-inst-navy font-semibold text-base mb-1" style="font-family: 'Source Serif 4', serif; font-weight: 700;">Social Events</h3>
            <p class="text-inst-gray text-sm leading-relaxed" style="font-family: 'Inter', sans-serif;">
              Game nights, barbecues, trivia, and casual networking. Building community beyond the classroom.
            </p>
          </div>
        </div>
      </div>

      <div class="reveal bg-inst-bg p-8 md:p-10">
        <div class="flex items-start gap-4">
          <div class="w-10 h-10 bg-inst-accent/10 rounded-lg flex items-center justify-center text-inst-accent shrink-0">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
          </div>
          <div>
            <h3 class="text-inst-navy font-semibold text-base mb-1" style="font-family: 'Source Serif 4', serif; font-weight: 700;">Industry Nights</h3>
            <p class="text-inst-gray text-sm leading-relaxed" style="font-family: 'Inter', sans-serif;">
              Direct connections with hiring companies. Hear from practising engineers and explore career pathways.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<%# ═══════════════════════════════════════════════════════════
    EVENTS — Table-like layout
