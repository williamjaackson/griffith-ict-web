<%# ═══════════════════════════════════════════════════════════
    HERO — Structured, two-column, formal
    ═══════════════════════════════════════════════════════════ %>
<header class="pt-28 md:pt-36 pb-20 md:pb-28 px-6 border-b border-inst-border">
  <div class="max-w-6xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-end">
      <div>
        <p class="animate-fade-up text-inst-accent font-semibold text-sm tracking-wider uppercase mb-5" style="font-family: 'Inter', sans-serif;">
          Griffith University Student Organisation
