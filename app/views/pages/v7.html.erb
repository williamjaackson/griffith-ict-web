    <div class="border border-inst-border bg-white rounded-lg overflow-hidden">
      <%# Header row %>
      <div class="hidden md:grid grid-cols-12 gap-4 px-6 py-3 bg-inst-light border-b border-inst-border text-inst-gray text-xs font-semibold uppercase tracking-wider" style="font-family: 'Inter', sans-serif;">
