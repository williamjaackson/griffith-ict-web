<%# ═══════════════════════════════════════════════════════════
    HERO — Playful, asymmetric, colourful blobs
    ═══════════════════════════════════════════════════════════ %>
<header class="relative min-h-screen flex items-center overflow-hidden px-6 pt-20 pb-16">
  <%# Colourful decorative blobs %>
  <div class="absolute top-[10%] right-[5%] w-64 h-64 md:w-96 md:h-96 bg-pop-pink/20 rounded-full blur-3xl pointer-events-none"></div>
  <div class="absolute bottom-[20%] left-[-5%] w-48 h-48 md:w-72 md:h-72 bg-pop-blue/20 rounded-full blur-3xl pointer-events-none"></div>
  <div class="absolute top-[50%] right-[30%] w-32 h-32 bg-pop-lime/25 rounded-full blur-2xl pointer-events-none"></div>
  <div class="absolute bottom-[10%] right-[10%] w-20 h-20 bg-pop-orange/30 rounded-full blur-xl pointer-events-none"></div>

  <div class="relative z-10 max-w-7xl mx-auto w-full">
    <div class="max-w-3xl">
      <div class="animate-fade-up flex flex-wrap gap-2 mb-8">
        <span class="inline-block bg-pop-pink/10 text-pop-pink text-xs font-bold px-4 py-1.5 rounded-full" style="font-family: 'Space Grotesk', sans-serif;">STUDENT CLUB</span>
        <span class="inline-block bg-pop-blue/10 text-pop-blue text-xs font-bold px-4 py-1.5 rounded-full" style="font-family: 'Space Grotesk', sans-serif;">GRIFFITH UNI</span>
        <span class="inline-block bg-pop-lime/15 text-pop-lime text-xs font-bold px-4 py-1.5 rounded-full brightness-75" style="font-family: 'Space Grotesk', sans-serif;">EST. 2020</span>
      </div>

      <h1 class="animate-fade-up-1 text-5xl sm:text-6xl md:text-7xl lg:text-8xl text-pop-dark leading-[0.95] mb-8" style="font-family: 'Space Grotesk', sans-serif; font-weight: 700;">
        Build.<br>
        <span class="text-pop-pink">Learn.</span><br>
        <span class="text-pop-blue">Connect.</span>
      </h1>

      <p class="animate-fade-up-2 text-pop-gray text-lg md:text-xl max-w-xl leading-relaxed mb-10" style="font-family: 'DM Sans', sans-serif;">
        We're an inclusive community of students passionate about technology.
        Whether you're writing your first line of code or deploying to production,
        there's a place for you here.
      </p>

      <div class="animate-fade-up-3 flex flex-wrap items-center gap-4 mb-14">
        <a href="#community" class="bg-pop-dark text-white font-bold px-8 py-4 rounded-full transition-all duration-200 hover:scale-105 hover:shadow-xl text-base" style="font-family: 'Space Grotesk', sans-serif;">
          Join our Discord
        </a>
        <a href="#about" class="bg-pop-light text-pop-dark font-bold px-8 py-4 rounded-full transition-all duration-200 hover:bg-gray-100 text-base" style="font-family: 'Space Grotesk', sans-serif;">
          Learn more
        </a>
      </div>

      <div class="animate-fade-up-4 flex flex-wrap gap-6 md:gap-10">
        <div class="flex items-center gap-3">
          <span class="flex items-center justify-center w-12 h-12 bg-pop-pink/10 rounded-2xl text-pop-pink text-lg font-extrabold" style="font-family: 'Space Grotesk', sans-serif;">200+</span>
          <span class="text-pop-gray text-sm font-medium" style="font-family: 'DM Sans', sans-serif;">Members</span>
        </div>
        <div class="flex items-center gap-3">
          <span class="flex items-center justify-center w-12 h-12 bg-pop-blue/10 rounded-2xl text-pop-blue text-lg font-extrabold" style="font-family: 'Space Grotesk', sans-serif;">50+</span>
          <span class="text-pop-gray text-sm font-medium" style="font-family: 'DM Sans', sans-serif;">Events / yr</span>
        </div>
        <div class="flex items-center gap-3">
          <span class="flex items-center justify-center w-12 h-12 bg-pop-orange/10 rounded-2xl text-pop-orange text-lg font-extrabold" style="font-family: 'Space Grotesk', sans-serif;">2</span>
          <span class="text-pop-gray text-sm font-medium" style="font-family: 'DM Sans', sans-serif;">Campuses</span>
        </div>
      </div>
    </div>
  </div>
</header>

<%# ═══════════════════════════════════════════════════════════
    ABOUT — Colourful card grid
    ═══════════════════════════════════════════════════════════ %>
<section id="about" class="py-24 md:py-32 px-6">
  <div class="max-w-6xl mx-auto">
    <div class="reveal text-center mb-16">
      <span class="inline-block bg-pop-lime/15 text-pop-gray text-xs font-bold px-4 py-1.5 rounded-full mb-4" style="font-family: 'Space Grotesk', sans-serif;">WHAT WE DO</span>
      <h2 class="text-3xl md:text-5xl text-pop-dark font-bold mb-4" style="font-family: 'Space Grotesk', sans-serif;">By students, for students.</h2>
      <p class="text-pop-gray text-lg max-w-2xl mx-auto leading-relaxed" style="font-family: 'DM Sans', sans-serif;">
        GIC is Griffith University's ICT club, based across Nathan and Gold Coast campuses.
        We exist to help students build skills, make friends, and kickstart their careers in tech.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
      <div class="reveal bg-pop-pink/5 border-2 border-pop-pink/20 rounded-3xl p-8 transition-all duration-300 hover:scale-[1.02] hover:border-pop-pink/40">
        <div class="w-14 h-14 bg-pop-pink/10 rounded-2xl flex items-center justify-center text-2xl mb-5">&#x1F4BB;</div>
        <h3 class="text-pop-dark font-bold text-xl mb-2" style="font-family: 'Space Grotesk', sans-serif;">Workshops</h3>
        <p class="text-pop-gray text-sm leading-relaxed" style="font-family: 'DM Sans', sans-serif;">
          Hands-on sessions covering web dev, cloud, AI, cybersecurity, and more.
          Learn by building real things with people who get it.
        </p>
      </div>

      <div class="reveal bg-pop-blue/5 border-2 border-pop-blue/20 rounded-3xl p-8 transition-all duration-300 hover:scale-[1.02] hover:border-pop-blue/40">
        <div class="w-14 h-14 bg-pop-blue/10 rounded-2xl flex items-center justify-center text-2xl mb-5">&#x1F3C6;</div>
        <h3 class="text-pop-dark font-bold text-xl mb-2" style="font-family: 'Space Grotesk', sans-serif;">Hackathons</h3>
        <p class="text-pop-gray text-sm leading-relaxed" style="font-family: 'DM Sans', sans-serif;">
          Team up, ship fast, win prizes. We run our own hackathons and send teams
          to national competitions.
        </p>
      </div>

      <div class="reveal bg-pop-orange/5 border-2 border-pop-orange/20 rounded-3xl p-8 transition-all duration-300 hover:scale-[1.02] hover:border-pop-orange/40">
        <div class="w-14 h-14 bg-pop-orange/10 rounded-2xl flex items-center justify-center text-2xl mb-5">&#x1F37B;</div>
        <h3 class="text-pop-dark font-bold text-xl mb-2" style="font-family: 'Space Grotesk', sans-serif;">Social Events</h3>
        <p class="text-pop-gray text-sm leading-relaxed" style="font-family: 'DM Sans', sans-serif;">
          Game nights, BBQs, trivia, and casual hangouts. The best part of uni
          is the people — we make sure you meet them.
        </p>
      </div>

      <div class="reveal bg-pop-lime/5 border-2 border-pop-lime/20 rounded-3xl p-8 transition-all duration-300 hover:scale-[1.02] hover:border-pop-lime/40">
        <div class="w-14 h-14 bg-pop-lime/10 rounded-2xl flex items-center justify-center text-2xl mb-5">&#x1F454;</div>
        <h3 class="text-pop-dark font-bold text-xl mb-2" style="font-family: 'Space Grotesk', sans-serif;">Industry Nights</h3>
        <p class="text-pop-gray text-sm leading-relaxed" style="font-family: 'DM Sans', sans-serif;">
          Connect with companies hiring grads. Hear from engineers, ask questions,
          and get your foot in the door before you graduate.
        </p>
      </div>
    </div>
  </div>
</section>

<%# ═══════════════════════════════════════════════════════════
    EVENTS — Colourful pill tags, horizontal scroll feel
    ═══════════════════════════════════════════════════════════ %>
<section id="events" class="py-24 md:py-32 px-6 bg-pop-light">
  <div class="max-w-6xl mx-auto">
    <div class="reveal text-center mb-16">
      <span class="inline-block bg-pop-blue/10 text-pop-blue text-xs font-bold px-4 py-1.5 rounded-full mb-4" style="font-family: 'Space Grotesk', sans-serif;">UPCOMING</span>
      <h2 class="text-3xl md:text-5xl text-pop-dark font-bold" style="font-family: 'Space Grotesk', sans-serif;">What's happening next</h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
      <%# Event 1 %>
      <article class="reveal bg-white rounded-3xl p-7 shadow-sm transition-all duration-300 hover:shadow-md hover:scale-[1.02]">
        <div class="flex items-center gap-3 mb-5">
          <span class="inline-block bg-pop-pink text-white text-xs font-bold px-3.5 py-1.5 rounded-full" style="font-family: 'Space Grotesk', sans-serif;">Workshop</span>
          <span class="text-pop-gray/50 text-xs font-medium" style="font-family: 'DM Sans', sans-serif;">12 Mar</span>
        </div>
        <h3 class="text-pop-dark font-bold text-lg mb-2" style="font-family: 'Space Grotesk', sans-serif;">Intro to Git & GitHub</h3>
        <p class="text-pop-gray text-sm leading-relaxed mb-4" style="font-family: 'DM Sans', sans-serif;">
          From your first commit to opening a pull request. All levels welcome.
        </p>
        <div class="flex flex-wrap gap-2">
          <span class="text-pop-gray/60 text-xs bg-pop-light px-3 py-1 rounded-full" style="font-family: 'DM Sans', sans-serif;">6:00 PM</span>
          <span class="text-pop-gray/60 text-xs bg-pop-light px-3 py-1 rounded-full" style="font-family: 'DM Sans', sans-serif;">Nathan, N44</span>
        </div>
      </article>

      <%# Event 2 %>
      <article class="reveal bg-white rounded-3xl p-7 shadow-sm transition-all duration-300 hover:shadow-md hover:scale-[1.02]">
        <div class="flex items-center gap-3 mb-5">
          <span class="inline-block bg-pop-lime text-white text-xs font-bold px-3.5 py-1.5 rounded-full brightness-75" style="font-family: 'Space Grotesk', sans-serif;">Social</span>
          <span class="text-pop-gray/50 text-xs font-medium" style="font-family: 'DM Sans', sans-serif;">19 Mar</span>
        </div>
        <h3 class="text-pop-dark font-bold text-lg mb-2" style="font-family: 'Space Grotesk', sans-serif;">Welcome Week BBQ</h3>
        <p class="text-pop-gray text-sm leading-relaxed mb-4" style="font-family: 'DM Sans', sans-serif;">
          Free food, lawn games, and good vibes. Bring your mates or come solo.
        </p>
        <div class="flex flex-wrap gap-2">
          <span class="text-pop-gray/60 text-xs bg-pop-light px-3 py-1 rounded-full" style="font-family: 'DM Sans', sans-serif;">12:00 PM</span>
          <span class="text-pop-gray/60 text-xs bg-pop-light px-3 py-1 rounded-full" style="font-family: 'DM Sans', sans-serif;">Gold Coast, G40</span>
        </div>
      </article>

      <%# Event 3 %>
      <article class="reveal bg-white rounded-3xl p-7 shadow-sm transition-all duration-300 hover:shadow-md hover:scale-[1.02]">
        <div class="flex items-center gap-3 mb-5">
          <span class="inline-block bg-pop-blue text-white text-xs font-bold px-3.5 py-1.5 rounded-full" style="font-family: 'Space Grotesk', sans-serif;">Hackathon</span>
          <span class="text-pop-gray/50 text-xs font-medium" style="font-family: 'DM Sans', sans-serif;">02 Apr</span>
        </div>
        <h3 class="text-pop-dark font-bold text-lg mb-2" style="font-family: 'Space Grotesk', sans-serif;">GIC Hack Day 2026</h3>
        <p class="text-pop-gray text-sm leading-relaxed mb-4" style="font-family: 'DM Sans', sans-serif;">
          24 hours. One idea. Ship something awesome. Teams of 2–4, all skill levels.
        </p>
        <div class="flex flex-wrap gap-2">
          <span class="text-pop-gray/60 text-xs bg-pop-light px-3 py-1 rounded-full" style="font-family: 'DM Sans', sans-serif;">9 AM – 9 AM</span>
          <span class="text-pop-gray/60 text-xs bg-pop-light px-3 py-1 rounded-full" style="font-family: 'DM Sans', sans-serif;">Nathan, N78</span>
        </div>
      </article>
    </div>

    <div class="reveal text-center mt-12">
      <a href="#community" class="inline-flex items-center gap-2 bg-pop-dark text-white font-bold px-7 py-3 rounded-full transition-all duration-200 hover:scale-105 text-sm" style="font-family: 'Space Grotesk', sans-serif;">
        See all events
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
    </div>
  </div>
</section>

