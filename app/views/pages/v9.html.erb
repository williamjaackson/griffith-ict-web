<%# ═══════════════════════════════════════════════════════════
    HERO — Centered, airy, maximum whitespace
    ═══════════════════════════════════════════════════════════ %>
<header class="min-h-screen flex flex-col items-center justify-center text-center px-6 pt-20">
  <div class="max-w-3xl mx-auto">
    <div class="animate-fade-up inline-flex items-center gap-2 bg-red-500/5 border border-red-500/15 text-red-500 text-xs font-semibold px-4 py-1.5 rounded-full mb-8" style="font-family: 'Albert Sans', sans-serif;">
      <span class="w-1.5 h-1.5 bg-red-500 rounded-full"></span>
      Griffith University's student tech community
    </div>

    <h1 class="animate-fade-up-1 text-4xl sm:text-5xl md:text-6xl lg:text-7xl text-mod-dark leading-[1.05] tracking-tight mb-6" style="font-family: 'Albert Sans', sans-serif; font-weight: 800;">
      Build. Learn.<br>Connect.
    </h1>

    <p class="animate-fade-up-2 text-mod-gray text-lg md:text-xl max-w-lg mx-auto leading-relaxed mb-10" style="font-family: 'IBM Plex Sans', sans-serif;">
      An inclusive community of students passionate about technology.
      There's a place for you here.
    </p>

    <div class="animate-fade-up-3 flex flex-col sm:flex-row items-center justify-center gap-3 mb-20">
      <a href="#community" class="bg-mod-dark hover:bg-mod-dark/90 text-white font-semibold px-7 py-3 rounded-full transition-all duration-200 hover:shadow-lg text-sm" style="font-family: 'Albert Sans', sans-serif;">
        Join our Discord
      </a>
      <a href="#about" class="text-mod-gray hover:text-mod-dark font-medium px-7 py-3 rounded-full transition-all duration-200 text-sm" style="font-family: 'Albert Sans', sans-serif;">
        Learn more &darr;
      </a>
    </div>

    <div class="animate-fade-up-4 flex items-center justify-center gap-12 md:gap-16">
      <div class="text-center">
        <span class="block text-3xl md:text-4xl text-mod-dark font-bold tracking-tight" style="font-family: 'Albert Sans', sans-serif;">200+</span>
        <span class="text-mod-muted text-xs font-medium tracking-wide uppercase" style="font-family: 'IBM Plex Sans', sans-serif;">Members</span>
      </div>
      <div class="w-px h-10 bg-mod-border"></div>
      <div class="text-center">
        <span class="block text-3xl md:text-4xl text-mod-dark font-bold tracking-tight" style="font-family: 'Albert Sans', sans-serif;">50+</span>
        <span class="text-mod-muted text-xs font-medium tracking-wide uppercase" style="font-family: 'IBM Plex Sans', sans-serif;">Events / yr</span>
      </div>
      <div class="w-px h-10 bg-mod-border"></div>
      <div class="text-center">
        <span class="block text-3xl md:text-4xl text-mod-dark font-bold tracking-tight" style="font-family: 'Albert Sans', sans-serif;">2</span>
        <span class="text-mod-muted text-xs font-medium tracking-wide uppercase" style="font-family: 'IBM Plex Sans', sans-serif;">Campuses</span>
      </div>
    </div>
  </div>
</header>

<%# ═══════════════════════════════════════════════════════════
    ABOUT — Clean, barely-there cards
    ═══════════════════════════════════════════════════════════ %>
<section id="about" class="py-28 md:py-36 px-6">
  <div class="max-w-5xl mx-auto">
    <div class="reveal max-w-2xl mb-16">
      <p class="text-red-500 text-xs font-semibold tracking-widest uppercase mb-4" style="font-family: 'Albert Sans', sans-serif;">What we do</p>
      <h2 class="text-3xl md:text-4xl text-mod-dark tracking-tight mb-4" style="font-family: 'Albert Sans', sans-serif; font-weight: 700;">By students, for students.</h2>
      <p class="text-mod-gray text-base leading-relaxed" style="font-family: 'IBM Plex Sans', sans-serif;">
        GIC is Griffith University's ICT club, based across Nathan (Brisbane / Meanjin)
        and Gold Coast (Yugambeh) campuses. We help students build skills, make friends,
        and kickstart their careers in tech.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-px bg-mod-border rounded-2xl overflow-hidden">
      <div class="reveal bg-white p-7 transition-colors duration-200 hover:bg-mod-surface">
        <div class="w-9 h-9 bg-red-500/8 rounded-lg flex items-center justify-center mb-4">
          <svg class="w-4.5 h-4.5 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
        </div>
        <h3 class="text-mod-dark font-semibold text-sm mb-1.5" style="font-family: 'Albert Sans', sans-serif;">Workshops</h3>
        <p class="text-mod-muted text-sm leading-relaxed" style="font-family: 'IBM Plex Sans', sans-serif;">
          Web dev, cloud, AI, cybersecurity. Hands-on, practical, all levels.
        </p>
      </div>

      <div class="reveal bg-white p-7 transition-colors duration-200 hover:bg-mod-surface">
        <div class="w-9 h-9 bg-red-500/8 rounded-lg flex items-center justify-center mb-4">
          <svg class="w-4.5 h-4.5 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
        </div>
        <h3 class="text-mod-dark font-semibold text-sm mb-1.5" style="font-family: 'Albert Sans', sans-serif;">Hackathons</h3>
        <p class="text-mod-muted text-sm leading-relaxed" style="font-family: 'IBM Plex Sans', sans-serif;">
          Team up, ship fast, win prizes. Local events and national competitions.
        </p>
      </div>

      <div class="reveal bg-white p-7 transition-colors duration-200 hover:bg-mod-surface">
        <div class="w-9 h-9 bg-red-500/8 rounded-lg flex items-center justify-center mb-4">
          <svg class="w-4.5 h-4.5 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
        </div>
        <h3 class="text-mod-dark font-semibold text-sm mb-1.5" style="font-family: 'Albert Sans', sans-serif;">Social Events</h3>
        <p class="text-mod-muted text-sm leading-relaxed" style="font-family: 'IBM Plex Sans', sans-serif;">
          Game nights, BBQs, trivia. The people make the community.
        </p>
      </div>

      <div class="reveal bg-white p-7 transition-colors duration-200 hover:bg-mod-surface">
        <div class="w-9 h-9 bg-red-500/8 rounded-lg flex items-center justify-center mb-4">
          <svg class="w-4.5 h-4.5 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
        </div>
        <h3 class="text-mod-dark font-semibold text-sm mb-1.5" style="font-family: 'Albert Sans', sans-serif;">Industry Nights</h3>
        <p class="text-mod-muted text-sm leading-relaxed" style="font-family: 'IBM Plex Sans', sans-serif;">
          Meet hiring companies. Hear from engineers. Start your career early.
        </p>
      </div>
    </div>
  </div>
</section>

<%# ═══════════════════════════════════════════════════════════
    EVENTS — Clean list, generous spacing
    ═══════════════════════════════════════════════════════════ %>
<section id="events" class="py-28 md:py-36 px-6 bg-mod-surface">
  <div class="max-w-5xl mx-auto">
    <div class="reveal max-w-2xl mb-16">
      <p class="text-red-500 text-xs font-semibold tracking-widest uppercase mb-4" style="font-family: 'Albert Sans', sans-serif;">Upcoming</p>
      <h2 class="text-3xl md:text-4xl text-mod-dark tracking-tight" style="font-family: 'Albert Sans', sans-serif; font-weight: 700;">What's happening next</h2>
    </div>

    <div class="flex flex-col">
      <%# Event 1 %>
      <article class="reveal flex flex-col sm:flex-row gap-6 py-8 border-b border-mod-border group">
        <div class="sm:w-28 shrink-0">
          <span class="text-mod-dark font-semibold text-sm" style="font-family: 'Albert Sans', sans-serif;">Mar 12</span>
          <span class="block text-mod-muted text-xs mt-0.5" style="font-family: 'IBM Plex Sans', sans-serif;">6:00 PM</span>
        </div>
        <div class="flex-1">
          <div class="flex items-center gap-3 mb-2">
            <h3 class="text-mod-dark font-semibold text-base group-hover:text-red-500 transition-colors" style="font-family: 'Albert Sans', sans-serif;">Intro to Git & GitHub</h3>
            <span class="text-xs font-medium text-red-500 bg-red-500/5 border border-red-500/15 px-2.5 py-0.5 rounded-full" style="font-family: 'Albert Sans', sans-serif;">Workshop</span>
          </div>
          <p class="text-mod-gray text-sm leading-relaxed mb-2" style="font-family: 'IBM Plex Sans', sans-serif;">
            From your first commit to opening a pull request. All levels welcome.
          </p>
          <span class="text-mod-muted text-xs" style="font-family: 'IBM Plex Sans', sans-serif;">Nathan Campus, N44</span>
        </div>
      </article>

      <%# Event 2 %>
      <article class="reveal flex flex-col sm:flex-row gap-6 py-8 border-b border-mod-border group">
        <div class="sm:w-28 shrink-0">
          <span class="text-mod-dark font-semibold text-sm" style="font-family: 'Albert Sans', sans-serif;">Mar 19</span>
          <span class="block text-mod-muted text-xs mt-0.5" style="font-family: 'IBM Plex Sans', sans-serif;">12:00 PM</span>
        </div>
        <div class="flex-1">
          <div class="flex items-center gap-3 mb-2">
            <h3 class="text-mod-dark font-semibold text-base group-hover:text-red-500 transition-colors" style="font-family: 'Albert Sans', sans-serif;">Welcome Week BBQ</h3>
            <span class="text-xs font-medium text-emerald-600 bg-emerald-500/5 border border-emerald-500/15 px-2.5 py-0.5 rounded-full" style="font-family: 'Albert Sans', sans-serif;">Social</span>
          </div>
          <p class="text-mod-gray text-sm leading-relaxed mb-2" style="font-family: 'IBM Plex Sans', sans-serif;">
            Free food, lawn games, and good vibes. Bring your mates or come solo.
          </p>
          <span class="text-mod-muted text-xs" style="font-family: 'IBM Plex Sans', sans-serif;">Gold Coast Campus, G40 Lawn</span>
        </div>
      </article>

      <%# Event 3 %>
      <article class="reveal flex flex-col sm:flex-row gap-6 py-8 group">
        <div class="sm:w-28 shrink-0">
          <span class="text-mod-dark font-semibold text-sm" style="font-family: 'Albert Sans', sans-serif;">Apr 02</span>
          <span class="block text-mod-muted text-xs mt-0.5" style="font-family: 'IBM Plex Sans', sans-serif;">9:00 AM</span>
        </div>
        <div class="flex-1">
          <div class="flex items-center gap-3 mb-2">
            <h3 class="text-mod-dark font-semibold text-base group-hover:text-red-500 transition-colors" style="font-family: 'Albert Sans', sans-serif;">GIC Hack Day 2026</h3>
            <span class="text-xs font-medium text-violet-600 bg-violet-500/5 border border-violet-500/15 px-2.5 py-0.5 rounded-full" style="font-family: 'Albert Sans', sans-serif;">Hackathon</span>
          </div>
          <p class="text-mod-gray text-sm leading-relaxed mb-2" style="font-family: 'IBM Plex Sans', sans-serif;">
            24 hours. One idea. Ship something awesome. Teams of 2–4, all skill levels.
          </p>
          <span class="text-mod-muted text-xs" style="font-family: 'IBM Plex Sans', sans-serif;">Nathan Campus, N78</span>
        </div>
      </article>
    </div>

    <div class="reveal mt-10">
      <a href="#community" class="inline-flex items-center gap-2 text-mod-dark hover:text-red-500 font-medium text-sm transition-colors" style="font-family: 'Albert Sans', sans-serif;">
        View all events
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
    </div>
  </div>
</section>

