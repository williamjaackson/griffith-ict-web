  <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
    <%# Logo %>
    <a href="#" class="flex items-center gap-3 group">
      <img src="/logo.png" alt="GIC" class="h-8 w-auto transition-transform duration-300 group-hover:scale-105">
    </a>

    <%# Desktop links %>
    <ul class="hidden md:flex items-center gap-8">
      <li><a href="#about" class="text-gray-400 hover:text-white transition-colors duration-200 text-sm font-medium">About</a></li>
      <li><a href="#events" class="text-gray-400 hover:text-white transition-colors duration-200 text-sm font-medium">Events</a></li>
      <li><a href="#community" class="text-gray-400 hover:text-white transition-colors duration-200 text-sm font-medium">Community</a></li>
      <li><a href="#sponsors" class="text-gray-400 hover:text-white transition-colors duration-200 text-sm font-medium">Sponsors</a></li>
    </ul>

    <%# Desktop CTA %>
    <a href="#community" class="hidden md:inline-flex items-center gap-2 bg-red-500 hover:bg-red-400 text-white text-sm font-semibold px-5 py-2.5 rounded-full transition-all duration-200 hover:shadow-[0_0_20px_rgba(240,62,62,0.4)] hover:scale-105">
      Join Us
    </a>

    <%# Mobile hamburger (CSS-only) %>
    <input type="checkbox" id="nav-toggle" class="nav__toggle-input hidden" aria-label="Toggle navigation">
    <label for="nav-toggle" class="md:hidden flex flex-col gap-1.5 cursor-pointer z-50 relative" aria-hidden="true">
      <span class="block w-6 h-0.5 bg-white transition-transform duration-300 origin-center"></span>
      <span class="block w-6 h-0.5 bg-white transition-opacity duration-300"></span>
      <span class="block w-6 h-0.5 bg-white transition-transform duration-300 origin-center"></span>
    </label>

    <%# Mobile menu overlay %>
    <div class="nav__menu fixed inset-0 bg-gray-950/95 backdrop-blur-xl flex flex-col items-center justify-center gap-8 opacity-0 pointer-events-none transition-all duration-500 md:hidden">
      <a href="#about" class="text-2xl font-display font-semibold text-white hover:text-red-500 transition-colors" onclick="document.getElementById('nav-toggle').checked = false">About</a>
      <a href="#events" class="text-2xl font-display font-semibold text-white hover:text-red-500 transition-colors" onclick="document.getElementById('nav-toggle').checked = false">Events</a>
      <a href="#community" class="text-2xl font-display font-semibold text-white hover:text-red-500 transition-colors" onclick="document.getElementById('nav-toggle').checked = false">Community</a>
