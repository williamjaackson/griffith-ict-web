    </div>
  </div>
</nav>

<%# ═══════════════════════════════════════════════════════════
    HERO
    ═══════════════════════════════════════════════════════════ %>
<header class="relative min-h-screen flex flex-col items-center justify-center text-center px-6 overflow-hidden">
  <%# Background glow %>
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] rounded-full bg-[radial-gradient(circle,rgba(240,62,62,0.12)_0%,transparent_70%)] pointer-events-none"></div>
  <div class="absolute top-1/4 right-1/4 w-[400px] h-[400px] rounded-full bg-[radial-gradient(circle,rgba(240,62,62,0.06)_0%,transparent_70%)] pointer-events-none"></div>

  <%# Content %>
  <div class="relative z-10 max-w-4xl mx-auto">
    <p class="animate-fade-up text-red-500 font-body font-medium text-sm md:text-base tracking-widest uppercase mb-6">
      Griffith University's student tech community
    </p>

    <h1 class="animate-fade-up-1 font-display font-extrabold text-5xl sm:text-6xl md:text-7xl lg:text-8xl text-white leading-[0.95] mb-8">
      Build. Learn.<br>
      <span class="text-red-500">Connect.</span>
    </h1>

    <p class="animate-fade-up-2 text-gray-400 text-lg md:text-xl max-w-2xl mx-auto leading-relaxed mb-10">
      We're an inclusive community of students passionate about technology.
      Whether you're writing your first line of code or deploying to production,
      there's a place for you here.
    </p>

    <div class="animate-fade-up-3 flex flex-col sm:flex-row items-center justify-center gap-4 mb-16">
      <a href="#community" class="bg-red-500 hover:bg-red-400 text-white font-semibold px-8 py-3.5 rounded-full transition-all duration-200 hover:shadow-[0_0_30px_rgba(240,62,62,0.4)] hover:scale-105 text-base">
        Join our Discord
      </a>
      <a href="#about" class="border border-gray-800 hover:border-gray-600 text-gray-200 hover:text-white font-medium px-8 py-3.5 rounded-full transition-all duration-200 hover:bg-gray-900 text-base">
        Learn more
      </a>
    </div>

    <div class="animate-fade-up-4 flex items-center justify-center gap-8 md:gap-16">
      <div class="text-center">
        <span class="block font-display font-bold text-2xl md:text-3xl text-white">200+</span>
        <span class="text-gray-600 text-sm font-medium">Members</span>
      </div>
      <div class="w-px h-10 bg-gray-800"></div>
      <div class="text-center">
        <span class="block font-display font-bold text-2xl md:text-3xl text-white">50+</span>
        <span class="text-gray-600 text-sm font-medium">Events / year</span>
      </div>
      <div class="w-px h-10 bg-gray-800"></div>
      <div class="text-center">
        <span class="block font-display font-bold text-2xl md:text-3xl text-white">2</span>
        <span class="text-gray-600 text-sm font-medium">Campuses</span>
      </div>
    </div>
  </div>

  <%# Scroll indicator %>
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-3 animate-fade-up-5">
    <span class="text-gray-600 text-xs tracking-[0.2em] uppercase font-medium">Scroll</span>
    <div class="w-px h-8 bg-gradient-to-b from-gray-600 to-transparent animate-pulse-line origin-top"></div>
  </div>
</header>

<%# ═══════════════════════════════════════════════════════════
    ABOUT
    ═══════════════════════════════════════════════════════════ %>
<section id="about" class="py-24 md:py-32 px-6">
  <div class="max-w-6xl mx-auto">
    <span class="reveal block text-red-500 font-body font-semibold text-sm tracking-widest uppercase mb-4">What we do</span>
    <h2 class="reveal font-display font-bold text-3xl md:text-5xl text-white mb-6">By students, for students.</h2>
    <p class="reveal text-gray-400 text-lg md:text-xl max-w-3xl leading-relaxed mb-16">
      GIC is Griffith University's ICT club, based across Nathan (Brisbane / Meanjin)
      and Gold Coast (Yugambeh) campuses. We exist to help students build skills,
      make friends, and kickstart their careers in tech — no matter their experience level.
    </p>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      <div class="reveal group bg-gray-900 border border-gray-800 rounded-2xl p-6 transition-all duration-300 hover:border-red-500/50 hover:shadow-[0_0_30px_rgba(240,62,62,0.08)]">
        <div class="text-3xl mb-4">&#x1F4BB;</div>
        <h3 class="font-display font-semibold text-lg text-white mb-2">Workshops</h3>
        <p class="text-gray-400 text-sm leading-relaxed">
          Hands-on sessions covering web dev, cloud, AI, cybersecurity, and more.
          Learn by building real things with people who get it.
        </p>
      </div>

      <div class="reveal group bg-gray-900 border border-gray-800 rounded-2xl p-6 transition-all duration-300 hover:border-red-500/50 hover:shadow-[0_0_30px_rgba(240,62,62,0.08)]">
        <div class="text-3xl mb-4">&#x1F3C6;</div>
        <h3 class="font-display font-semibold text-lg text-white mb-2">Hackathons</h3>
        <p class="text-gray-400 text-sm leading-relaxed">
          Team up, ship fast, win prizes. We run our own hackathons and send teams
          to national competitions.
        </p>
      </div>

      <div class="reveal group bg-gray-900 border border-gray-800 rounded-2xl p-6 transition-all duration-300 hover:border-red-500/50 hover:shadow-[0_0_30px_rgba(240,62,62,0.08)]">
        <div class="text-3xl mb-4">&#x1F37B;</div>
        <h3 class="font-display font-semibold text-lg text-white mb-2">Social Events</h3>
        <p class="text-gray-400 text-sm leading-relaxed">
          Game nights, BBQs, trivia, and casual hangouts. The best part of uni
          is the people — we make sure you meet them.
        </p>
      </div>

      <div class="reveal group bg-gray-900 border border-gray-800 rounded-2xl p-6 transition-all duration-300 hover:border-red-500/50 hover:shadow-[0_0_30px_rgba(240,62,62,0.08)]">
        <div class="text-3xl mb-4">&#x1F454;</div>
        <h3 class="font-display font-semibold text-lg text-white mb-2">Industry Nights</h3>
        <p class="text-gray-400 text-sm leading-relaxed">
          Connect with companies hiring grads. Hear from engineers, ask questions,
          and get your foot in the door before you graduate.
        </p>
      </div>
    </div>
  </div>
</section>

<%# ═══════════════════════════════════════════════════════════
    EVENTS
    ═══════════════════════════════════════════════════════════ %>
<section id="events" class="py-24 md:py-32 px-6">
  <div class="max-w-6xl mx-auto">
    <span class="reveal block text-red-500 font-body font-semibold text-sm tracking-widest uppercase mb-4">Upcoming</span>
    <h2 class="reveal font-display font-bold text-3xl md:text-5xl text-white mb-16">What's happening next</h2>

    <div class="flex flex-col gap-6">
      <%# Event 1: Workshop %>
      <article class="reveal flex flex-col sm:flex-row bg-gray-900 border border-gray-800 rounded-2xl overflow-hidden transition-all duration-300 hover:border-gray-600">
        <div class="flex sm:flex-col items-center justify-center bg-red-500 px-6 py-4 sm:py-6 sm:w-28 shrink-0">
          <span class="font-display font-bold text-3xl text-white mr-2 sm:mr-0">12</span>
          <span class="text-white/80 text-sm font-semibold uppercase tracking-wider">MAR</span>
        </div>
        <div class="p-6 flex-1">
          <span class="inline-block bg-red-500/10 text-red-400 text-xs font-semibold px-3 py-1 rounded-full mb-3">Workshop</span>
          <h3 class="font-display font-semibold text-xl text-white mb-2">Intro to Git & GitHub</h3>
          <p class="text-gray-400 text-sm leading-relaxed mb-4">
            Never used version control? No worries. We'll walk through everything
            from your first commit to opening a pull request.
          </p>
          <div class="flex flex-wrap gap-4 text-gray-600 text-xs font-medium">
            <span class="flex items-center gap-1.5">
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6l4 2"/><circle cx="12" cy="12" r="10"/></svg>
              6:00 PM
            </span>
            <span class="flex items-center gap-1.5">
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              Nathan Campus, N44
            </span>
          </div>
        </div>
      </article>

      <%# Event 2: Social %>
      <article class="reveal flex flex-col sm:flex-row bg-gray-900 border border-gray-800 rounded-2xl overflow-hidden transition-all duration-300 hover:border-gray-600">
        <div class="flex sm:flex-col items-center justify-center bg-emerald-600 px-6 py-4 sm:py-6 sm:w-28 shrink-0">
          <span class="font-display font-bold text-3xl text-white mr-2 sm:mr-0">19</span>
          <span class="text-white/80 text-sm font-semibold uppercase tracking-wider">MAR</span>
        </div>
        <div class="p-6 flex-1">
          <span class="inline-block bg-emerald-500/10 text-emerald-400 text-xs font-semibold px-3 py-1 rounded-full mb-3">Social</span>
          <h3 class="font-display font-semibold text-xl text-white mb-2">Welcome Week BBQ</h3>
          <p class="text-gray-400 text-sm leading-relaxed mb-4">
            Kick off the semester with free food, lawn games, and good vibes.
            Bring your mates or come solo — everyone's welcome.
          </p>
          <div class="flex flex-wrap gap-4 text-gray-600 text-xs font-medium">
            <span class="flex items-center gap-1.5">
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6l4 2"/><circle cx="12" cy="12" r="10"/></svg>
              12:00 PM
            </span>
            <span class="flex items-center gap-1.5">
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              Gold Coast Campus, G40 Lawn
            </span>
          </div>
        </div>
      </article>

      <%# Event 3: Hackathon %>
      <article class="reveal flex flex-col sm:flex-row bg-gray-900 border border-gray-800 rounded-2xl overflow-hidden transition-all duration-300 hover:border-gray-600">
        <div class="flex sm:flex-col items-center justify-center bg-violet-600 px-6 py-4 sm:py-6 sm:w-28 shrink-0">
          <span class="font-display font-bold text-3xl text-white mr-2 sm:mr-0">02</span>
          <span class="text-white/80 text-sm font-semibold uppercase tracking-wider">APR</span>
        </div>
        <div class="p-6 flex-1">
          <span class="inline-block bg-violet-500/10 text-violet-400 text-xs font-semibold px-3 py-1 rounded-full mb-3">Hackathon</span>
          <h3 class="font-display font-semibold text-xl text-white mb-2">GIC Hack Day 2026</h3>
          <p class="text-gray-400 text-sm leading-relaxed mb-4">
            24 hours. One idea. Ship something awesome. Teams of 2–4, all skill
            levels, with prizes and pizza.
          </p>
          <div class="flex flex-wrap gap-4 text-gray-600 text-xs font-medium">
            <span class="flex items-center gap-1.5">
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6l4 2"/><circle cx="12" cy="12" r="10"/></svg>
              9:00 AM – 9:00 AM
            </span>
            <span class="flex items-center gap-1.5">
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              Nathan Campus, N78
            </span>
          </div>
        </div>
      </article>
    </div>

    <div class="reveal text-center mt-12">
      <a href="#community" class="inline-flex items-center gap-2 border border-gray-800 hover:border-gray-600 text-gray-200 hover:text-white font-medium px-6 py-3 rounded-full transition-all duration-200 hover:bg-gray-900 text-sm">
        See all events on Discord
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
    </div>
  </div>
</section>

