<section data-controller="counter" data-counter-since-value="<%= Rails.application.config.meta[:established_at] %>">
  <div class="container">
    <div class="mb-16 reveal">
      <h2 class="heading">Since <span class="heading-highlight">day one.</span></h2>
      <p class="text-brand-gray text-lg max-w-2xl leading-relaxed">
        Established 2025. Here's how long we've been building, learning, and connecting.
      </p>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-5 reveal stagger">
      <div class="card" style="background-color: var(--color-brand-red);">
        <span data-counter-target="days" class="block text-4xl md:text-5xl font-extrabold text-white heading">&mdash;</span>
        <span class="text-white/70 text-sm font-semibold">Days</span>
      </div>

      <div class="card" style="background-color: var(--color-brand-red-50);">
        <span data-counter-target="hours" class="block text-4xl md:text-5xl font-extrabold text-brand-black heading">&mdash;</span>
        <span class="text-brand-gray text-sm font-semibold">Hours</span>
      </div>

      <div class="card">
        <span data-counter-target="minutes" class="block text-4xl md:text-5xl font-extrabold text-brand-black heading">&mdash;</span>
        <span class="text-brand-gray text-sm font-semibold">Minutes</span>
      </div>

      <div class="card" style="background-color: var(--color-brand-cream);">
        <span data-counter-target="seconds" class="block text-4xl md:text-5xl font-extrabold text-brand-black heading">&mdash;</span>
        <span class="text-brand-gray text-sm font-semibold">Seconds</span>
      </div>
    </div>
  </div>
</section>
