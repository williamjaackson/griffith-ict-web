<section class="py-24 md:py-32 px-6 border-t-3 border-brand-black bg-brand-cream" data-controller="reveal counter" data-counter-since-value="<%= Rails.application.config.meta[:established_at] %>">
  <div class="max-w-6xl mx-auto">
    <div class="mb-16 reveal-up" data-reveal-target="item">
      <h2 class="heading">Since <span class="heading-highlight">day one.</span></h2>
      <p class="text-brand-gray text-lg max-w-2xl leading-relaxed">
        Established 2025. Here's how long we've been building, learning, and connecting.
      </p>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-5">
      <div class="reveal-up" data-reveal-target="item" style="transition-delay: 100ms;">
        <div class="card" style="background-color: var(--color-brand-red);">
          <span data-counter-target="days" class="block text-4xl md:text-5xl font-extrabold text-white" style="font-family: 'Unbounded', sans-serif;">&mdash;</span>
          <span class="text-white/70 text-sm font-semibold">Days</span>
        </div>
      </div>

      <div class="reveal-up" data-reveal-target="item" style="transition-delay: 200ms;">
        <div class="card" style="background-color: var(--color-brand-red-50);">
          <span data-counter-target="hours" class="block text-4xl md:text-5xl font-extrabold text-brand-black" style="font-family: 'Unbounded', sans-serif;">&mdash;</span>
          <span class="text-brand-gray text-sm font-semibold">Hours</span>
        </div>
      </div>

      <div class="reveal-up" data-reveal-target="item" style="transition-delay: 300ms;">
        <div class="card">
          <span data-counter-target="minutes" class="block text-4xl md:text-5xl font-extrabold text-brand-black" style="font-family: 'Unbounded', sans-serif;">&mdash;</span>
          <span class="text-brand-gray text-sm font-semibold">Minutes</span>
        </div>
      </div>

      <div class="reveal-up" data-reveal-target="item" style="transition-delay: 400ms;">
        <div class="card" style="background-color: var(--color-brand-cream);">
          <span data-counter-target="seconds" class="block text-4xl md:text-5xl font-extrabold text-brand-black" style="font-family: 'Unbounded', sans-serif;">&mdash;</span>
          <span class="text-brand-gray text-sm font-semibold">Seconds</span>
        </div>
      </div>
    </div>
  </div>
</section>
