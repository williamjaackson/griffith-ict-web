<style>
  @keyframes hero-in {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-hero-in { animation: hero-in 0.4s cubic-bezier(0.2, 0, 0, 1) both; }
</style>

<header class="px-6 pt-8 pb-24">
  <div class="max-w-6xl mx-auto">
    <div class="animate-hero-in">
      <%= ui_badge("ABOUT", class: "-rotate-2 mb-8") %>
    </div>
    <div class="animate-hero-in" style="animation-delay: 100ms;">
      <%= ui_heading("Meet the club.", level: 1, highlight: "the club.") %>
    </div>
    <p class="animate-hero-in text-brand-gray text-lg md:text-xl max-w-2xl leading-relaxed mb-10" style="animation-delay: 200ms;">
      Griffith ICT Club is Griffith University's student-run tech community. We run events, hackathons, and workshops across the Gold Coast and Nathan campuses.
    </p>
    <div class="animate-hero-in flex flex-wrap gap-4" style="animation-delay: 300ms;">
      <%= ui_button("Become a Member", variant: :primary, onclick: "window.dispatchEvent(new CustomEvent('membership-modal:open'))") %>
      <%= ui_button("Back to home", href: "/", variant: :secondary) %>
    </div>
  </div>
</header>
