<header class="min-h-screen flex items-center px-6 pt-20 pb-16">
  <div class="max-w-6xl mx-auto w-full">
    <div class="grid grid-cols-1 lg:grid-cols-5 gap-8 items-center">
      <div class="lg:col-span-3">
        <div class="animate-fade-up inline-block bg-v13-red text-white border-3 border-v13-black px-4 py-1.5 mb-8 -rotate-2">
          <span class="text-sm font-bold" style="font-family: 'Unbounded', sans-serif; font-weight: 600;">GRIFFITH ICT CLUB</span>
