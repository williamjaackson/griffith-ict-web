          <span class="text-v13-gray text-sm font-semibold" style="font-family: 'Plus Jakarta Sans', sans-serif;">Partners</span>
        </div>
        <div class="flex-1 bg-v13-cream text-v13-black border-3 border-v13-black p-6 rotate-1 transition-all duration-200 hover:rotate-0">
          <span class="block text-4xl md:text-5xl font-extrabold" style="font-family: 'Unbounded', sans-serif;">2</span>
          <span class="text-v13-gray text-sm font-semibold" style="font-family: 'Plus Jakarta Sans', sans-serif;">Campuses</span>
