            Learn more
          </a>
        </div>
      </div>

      <%# Stats — stacked brutalist cards %>
      <div class="lg:col-span-2 flex flex-row lg:flex-col gap-4 animate-fade-up-4">
        <div class="flex-1 bg-v13-red text-white border-3 border-v13-black p-6 rotate-2 transition-all duration-200 hover:rotate-0">
          <span class="block text-4xl md:text-5xl font-extrabold" style="font-family: 'Unbounded', sans-serif;">400+</span>
          <span class="text-white/70 text-sm font-semibold" style="font-family: 'Plus Jakarta Sans', sans-serif;">Members</span>
        </div>
        <div class="flex-1 bg-v13-red-pale text-v13-black border-3 border-v13-black p-6 -rotate-1 transition-all duration-200 hover:rotate-0">
