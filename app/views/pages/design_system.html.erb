<div class="max-w-6xl mx-auto px-6 pt-8 flex flex-col items-start gap-8">
  <h1 class="heading heading-1">Heading <span class="heading-highlight">Numero Uno</span></h1>
  <h2 class="heading heading-2">Heading 2</h2>
  <h3 class="heading heading-3">Heading 3</h3>
  <h3 class="heading heading-4">Heading 4</h3>

  <p class="text-lg max-w-2xl leading-relaxed">Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris.</p>

  <div class="flex flex-wrap items-start gap-4">
    <span class="badge">Primary Badge</span>
    <span class="badge -rotate-2">Tilted Badge</span>
    <span class="badge badge-dark">Dark Badge</span>
    <span class="badge badge-sm">Small Badge</span>
    <span class="badge badge-sm" style="background-color: var(--color-brand-red-300);">Small Color Badge</span>
  </div>

  <div class="flex flex-wrap items-center gap-6">
    <%= image_tag "/logo/GriffithICTClubIcon.svg", alt: "Griffith ICT Club", class: "h-8 w-auto", draggable: "false" %>
    <%= image_tag "/logo/GriffithICTClubLogo.svg", alt: "Griffith ICT Club", class: "h-12 w-auto", draggable: "false" %>
  </div>

  <div class="flex flex-wrap items-start gap-4">
    <a href="#" class="btn btn-primary">Primary Button</a>
    <a href="#" class="btn btn-secondary">Secondary Button</a>
    <a href="#" class="btn btn-primary btn-sm">Small Button</a>
  </div>

  <div class="flex flex-wrap items-start gap-6">
    <div class="card" style="background-color: var(--color-brand-red);">
      <p class="text-white/80 text-sm">Coloured Card</p>
    </div>

    <div class="card" style="box-shadow: 5px 5px 0px var(--color-brand-red-300);">
      <h3 class="heading heading-3">Emphasised Card</h3>
    </div>

    <a href="#" class="card card-link" style="background-color: var(--color-brand-discord);">
      <p class="text-white/80 text-sm">Clickable Card</p>
    </a>

    <a href="#" class="card card-link hover:shadow-[5px_5px_0px_var(--color-brand-red-200)]">
      <div class="absolute left-0 top-0 bottom-0 w-3" style="background-color: var(--color-brand-red-200);"></div>
      <h3 class="heading heading-3">Card</h3>
      <p class="text-sm mt-1">That has a Sidebar</p>
    </a>
  </div>

  </br>
  </br>
  </br>
</div>
