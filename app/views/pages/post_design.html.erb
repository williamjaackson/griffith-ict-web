<div class="min-h-screen bg-neutral-400 flex items-center justify-center p-8">
  <div class="w-full max-w-[600px]">
    <div class="aspect-square bg-brand-red border-[6px] border-brand-black flex flex-col relative overflow-hidden">

      <style>
        .confetti-shape {
          position: absolute;
          border: 3px solid #222222;
        }
      </style>

      <%# === SCATTERED DECORATIVE SHAPES (confetti in brand style) === %>
      <%# Top-left cluster %>
      <div class="confetti-shape bg-brand-cream w-8 h-8 rotate-12" style="top: 6%; left: 5%;"></div>
      <div class="confetti-shape bg-brand-red-dark w-5 h-5 -rotate-6" style="top: 3%; left: 22%;"></div>
      <div class="confetti-shape bg-white w-4 h-10 rotate-[30deg]" style="top: 10%; left: 15%;"></div>
      <div class="confetti-shape bg-brand-discord w-6 h-6 rotate-45" style="top: 18%; left: 4%;"></div>

      <%# Top-right cluster %>
      <div class="confetti-shape bg-brand-black w-7 h-7 -rotate-12" style="top: 4%; right: 8%;"></div>
      <div class="confetti-shape bg-brand-cream w-4 h-12 rotate-[-20deg]" style="top: 8%; right: 20%;"></div>
      <div class="confetti-shape bg-brand-red-300 w-6 h-6 rotate-[25deg]" style="top: 16%; right: 5%;"></div>
      <div class="confetti-shape bg-white w-5 h-5 rotate-[55deg]" style="top: 2%; right: 30%;"></div>

      <%# Left side %>
      <div class="confetti-shape bg-brand-cream w-5 h-14 rotate-[-15deg]" style="top: 35%; left: 2%;"></div>
      <div class="confetti-shape bg-brand-black w-4 h-4 rotate-12" style="top: 55%; left: 6%;"></div>

      <%# Right side %>
      <div class="confetti-shape bg-white w-5 h-12 rotate-[20deg]" style="top: 40%; right: 3%;"></div>
      <div class="confetti-shape bg-brand-discord w-4 h-4 -rotate-12" style="top: 58%; right: 7%;"></div>

      <%# Bottom-left cluster %>
      <div class="confetti-shape bg-brand-black w-6 h-6 rotate-[35deg]" style="bottom: 12%; left: 6%;"></div>
      <div class="confetti-shape bg-white w-4 h-10 rotate-[-25deg]" style="bottom: 5%; left: 18%;"></div>
      <div class="confetti-shape bg-brand-cream w-7 h-7 rotate-12" style="bottom: 3%; left: 4%;"></div>

      <%# Bottom-right cluster %>
      <div class="confetti-shape bg-brand-cream w-5 h-5 -rotate-[30deg]" style="bottom: 10%; right: 10%;"></div>
      <div class="confetti-shape bg-brand-red-dark w-4 h-11 rotate-[15deg]" style="bottom: 4%; right: 22%;"></div>
      <div class="confetti-shape bg-brand-black w-8 h-8 rotate-45" style="bottom: 2%; right: 5%;"></div>
      <div class="confetti-shape bg-white w-5 h-5 rotate-[60deg]" style="bottom: 16%; right: 3%;"></div>

      <%# === MAIN CONTENT === %>
      <div class="flex-1 flex flex-col items-center justify-center relative z-10 px-8">

        <%# --- Milestone badge --- %>
        <div class="mb-4">
          <%= ui_badge("MILESTONE", variant: :dark, size: :sm, class: "rotate-[-2deg]") %>
        </div>

        <%# --- Big number --- %>
        <div class="text-center mb-1">
          <span class="block text-white font-extrabold leading-none" style="font-family: 'Unbounded', sans-serif; font-size: clamp(6rem, 20vw, 11rem); text-shadow: 4px 4px 0 #222222;">500</span>
        </div>

        <%# --- Members text --- %>
        <div class="mb-6">
          <%= ui_card(class: "!p-3 !px-8 !h-fit rotate-1") do %>
            <span class="text-brand-black font-extrabold text-2xl tracking-wide" style="font-family: 'Unbounded', sans-serif;">Members!</span>
          <% end %>
        </div>

        <%# --- Thank you text --- %>
        <p class="text-white/80 text-sm font-semibold mb-6 text-center" style="font-family: 'Plus Jakarta Sans', sans-serif;">
          Thank you for being part of our community.
        </p>

        <%# --- Logo --- %>
        <div class="flex justify-center">
          <%= ui_logo(type: :full, class: "!h-auto w-full max-w-[180px] brightness-0 invert") %>
        </div>

      </div>

      <%# === BOTTOM BAR === %>
      <div class="bg-brand-black border-t-3 border-brand-black px-5 py-3 flex items-center justify-between relative z-10">
        <div>
          <p class="text-white font-bold text-sm" style="font-family: 'Unbounded', sans-serif; font-weight: 700;">griffithict.club</p>
        </div>
        <div class="flex items-center gap-2.5">
