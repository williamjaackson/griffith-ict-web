<header class="px-6 pt-8 pb-24">
  <div class="max-w-6xl mx-auto">
    <%= ui_badge("SPONSORSHIP", class: "-rotate-2 mb-8") %>
    <%= ui_heading("Partner with us.", level: 1, highlight: "with us.") %>
    <p class="text-brand-gray text-lg md:text-xl max-w-2xl leading-relaxed mb-10">
      Help us run bigger events, better hackathons, and create real-world opportunities for 400+ students.
      In return, get direct access to Griffith's most engaged tech talent.
    </p>
    <div class="flex flex-wrap gap-4">
      <%= ui_button("Get in touch", href: "mailto:griffithictclub@gmail.com", variant: :primary) %>
      <%= ui_button("Back to home", href: "/", variant: :secondary) %>
    </div>
  </div>
</header>

<section class="py-24 md:py-32 px-6 border-t-3 border-brand-black bg-brand-cream">
  <div class="max-w-6xl mx-auto">
    <div class="mb-16">
      <%= ui_heading("Sponsorship tiers.", level: 2) %>
      <p class="text-brand-gray text-lg max-w-2xl leading-relaxed">
        Each tier builds on the one before it. Pick the level that fits your goals and budget.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <%# Bronze %>
      <%= ui_card(sidebar: "var(--color-brand-red-300)", class: "-rotate-2") do %>
        <%= ui_badge("BRONZE", size: :sm, color: "var(--color-brand-red-300)") %>
        <p class="text-brand-gray text-sm mt-4 mb-6 leading-relaxed">
          Get your brand in front of our members and show your support for the student tech community.
        </p>
        <ul class="flex flex-col gap-3 text-sm text-brand-gray">
          <li class="flex items-start gap-2">
            <span class="text-brand-red font-bold mt-0.5">&#10003;</span>
            Logo on club website
          </li>
          <li class="flex items-start gap-2">
            <span class="text-brand-red font-bold mt-0.5">&#10003;</span>
            Social media recognition
          </li>
          <li class="flex items-start gap-2">
            <span class="text-brand-red font-bold mt-0.5">&#10003;</span>
            Job and internship promotion
          </li>
          <li class="flex items-start gap-2">
            <span class="text-brand-red font-bold mt-0.5">&#10003;</span>
            Logo on event banners
          </li>
        </ul>
      <% end %>

      <%# Silver %>
      <%= ui_card(sidebar: "var(--color-brand-red)", class: "rotate-2") do %>
        <%= ui_badge("SILVER", size: :sm) %>
        <p class="text-brand-gray text-sm mt-4 mb-6 leading-relaxed">
          Everything in Bronze, plus direct access to students through events and panels.
        </p>
        <ul class="flex flex-col gap-3 text-sm text-brand-gray">
          <li class="flex items-start gap-2">
            <span class="text-brand-red font-bold mt-0.5">&#10003;</span>
            All Bronze benefits
          </li>
          <li class="flex items-start gap-2">
            <span class="text-brand-red font-bold mt-0.5">&#10003;</span>
            Representative at industry panels
          </li>
          <li class="flex items-start gap-2">
            <span class="text-brand-red font-bold mt-0.5">&#10003;</span>
            Access to networking events
          </li>
          <li class="flex items-start gap-2">
            <span class="text-brand-red font-bold mt-0.5">&#10003;</span>
            Newsletter and email promotion
          </li>
          <li class="flex items-start gap-2">
            <span class="text-brand-red font-bold mt-0.5">&#10003;</span>
            Promotional materials at events
          </li>
        </ul>
      <% end %>

      <%# Gold %>
      <%= ui_card(sidebar: "var(--color-brand-red-dark)", class: "-rotate-2") do %>
        <%= ui_badge("GOLD", size: :sm, color: "var(--color-brand-red-dark)") %>
        <p class="text-brand-gray text-sm mt-4 mb-6 leading-relaxed">
          The full partnership. A dedicated event, top billing, and first access to our talent pool.
        </p>
        <ul class="flex flex-col gap-3 text-sm text-brand-gray">
          <li class="flex items-start gap-2">
            <span class="text-brand-red font-bold mt-0.5">&#10003;</span>
            All Silver benefits
          </li>
          <li class="flex items-start gap-2">
            <span class="text-brand-red font-bold mt-0.5">&#10003;</span>
            Dedicated co-branded event
          </li>
          <li class="flex items-start gap-2">
            <span class="text-brand-red font-bold mt-0.5">&#10003;</span>
            Highest placement on all materials
          </li>
          <li class="flex items-start gap-2">
            <span class="text-brand-red font-bold mt-0.5">&#10003;</span>
            Tickets to annual networking night
          </li>
          <li class="flex items-start gap-2">
            <span class="text-brand-red font-bold mt-0.5">&#10003;</span>
            Direct access to member channels
          </li>
          <li class="flex items-start gap-2">
            <span class="text-brand-red font-bold mt-0.5">&#10003;</span>
            Merchandise branding opportunities
          </li>
        </ul>
      <% end %>
    </div>
  </div>
</section>

<section class="py-24 md:py-32 px-6 border-t-3 border-brand-black">
  <div class="max-w-6xl mx-auto">
    <div class="mb-16">
      <%= ui_heading("Why sponsor us?", level: 2) %>
      <p class="text-brand-gray text-lg max-w-2xl leading-relaxed">
        We're the largest tech club at Griffith. Here's what you get access to.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
      <%= ui_card(shadow: "var(--color-brand-red-300)") do %>
        <div class="w-10 h-10 bg-brand-red/10 flex items-center justify-center mb-4">
          <svg class="w-5 h-5 text-brand-red" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z"/></svg>
        </div>
        <%= ui_heading("400+ members", level: 3) %>
        <p class="text-brand-gray text-sm leading-relaxed">
          Engaged students across software, cybersecurity, data science, and IT — your future hires.
        </p>
      <% end %>

      <%= ui_card(shadow: "var(--color-brand-red-dark)") do %>
        <div class="w-10 h-10 bg-brand-red/10 flex items-center justify-center mb-4">
          <svg class="w-5 h-5 text-brand-red" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5"/></svg>
        </div>
        <%= ui_heading("Weekly events", level: 3) %>
        <p class="text-brand-gray text-sm leading-relaxed">
          Workshops, hackathons, game nights, and industry panels — consistent touchpoints with students.
        </p>
      <% end %>

      <%= ui_card(shadow: "var(--color-brand-red)") do %>
        <div class="w-10 h-10 bg-brand-red/10 flex items-center justify-center mb-4">
          <svg class="w-5 h-5 text-brand-red" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>
        </div>
        <%= ui_heading("2 campuses", level: 3) %>
        <p class="text-brand-gray text-sm leading-relaxed">
          Presence on both Gold Coast and Nathan campuses, reaching students across South East Queensland.
        </p>
      <% end %>

      <%= ui_card(shadow: "var(--color-brand-red-200)") do %>
        <div class="w-10 h-10 bg-brand-red/10 flex items-center justify-center mb-4">
          <svg class="w-5 h-5 text-brand-red" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3v11.25A2.25 2.25 0 006 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0118 16.5h-2.25m-7.5 0h7.5m-7.5 0l-1 3m8.5-3l1 3m0 0l.5 1.5m-.5-1.5h-9.5m0 0l-.5 1.5"/></svg>
        </div>
        <%= ui_heading("Real visibility", level: 3) %>
        <p class="text-brand-gray text-sm leading-relaxed">
          Your brand on our website, socials, Discord, merch, and at every event we run.
        </p>
      <% end %>
    </div>
  </div>
</section>

<section class="py-24 md:py-32 px-6 border-t-3 border-brand-black bg-brand-cream">
  <div class="max-w-6xl mx-auto text-center">
    <%= ui_heading("Ready to partner?", level: 2) %>
    <p class="text-brand-gray text-lg max-w-xl mx-auto leading-relaxed mb-10">
      Reach out and we'll send you our full sponsorship prospectus. We'd love to work with you.
    </p>
    <div class="flex flex-wrap justify-center gap-4">
      <%= ui_button("Get in touch", href: "mailto:griffithictclub@gmail.com", variant: :primary) %>
    </div>
  </div>
</section>
