<%# ═══════════════════════════════════════════════════════════
    SIGNATURE EVENTS — editorial cards with large dates
    ═══════════════════════════════════════════════════════════ %>
<section id="events" class="py-24 md:py-32">
  <div class="max-w-6xl mx-auto px-6">
    <div class="grid md:grid-cols-12 gap-12 md:gap-16 mb-16">
      <div class="md:col-span-5 reveal">
        <span class="text-prof-red text-xs font-semibold tracking-[0.2em] uppercase block mb-4" style="font-family: 'Figtree', sans-serif;">Events & Programs</span>
        <h2 class="text-3xl md:text-4xl text-prof-text leading-tight" style="font-family: 'Playfair Display', serif; font-weight: 700;">
          What a trimester looks like
        </h2>
      </div>
      <div class="md:col-span-7 reveal flex items-end">
        <p class="text-prof-secondary text-lg leading-relaxed" style="font-family: 'Figtree', sans-serif;">
          We run events every week during trimester — from low-key hangouts to multi-day hackathons. Here are our flagship programs.
        </p>
      </div>
    </div>

    <div class="grid md:grid-cols-2 gap-6">
      <!-- Tech & Chill -->
      <div class="reveal border border-prof-border rounded-2xl p-8 hover:shadow-lg hover:shadow-prof-dark/5 transition-all duration-300 group">
        <div class="flex items-start justify-between mb-4">
          <span class="text-prof-red text-xs font-bold tracking-[0.15em] uppercase px-3 py-1 bg-prof-red/5 rounded-full" style="font-family: 'Figtree', sans-serif;">Weekly</span>
        </div>
        <h3 class="text-2xl text-prof-text mb-3" style="font-family: 'Playfair Display', serif; font-weight: 700;">Tech & Chill</h3>
        <p class="text-prof-secondary leading-relaxed mb-4" style="font-family: 'Figtree', sans-serif;">
          Our signature weekly hangout. Couch co-op gaming, show & tell of personal projects, tech discussions, and free food. Every Wednesday during trimester. No agenda, no pressure.
        </p>
        <span class="text-prof-muted text-sm" style="font-family: 'Figtree', sans-serif;">Wednesdays &middot; Nathan & Gold Coast</span>
      </div>

      <!-- Hack Day -->
      <div class="reveal border border-prof-border rounded-2xl p-8 hover:shadow-lg hover:shadow-prof-dark/5 transition-all duration-300 group">
        <div class="flex items-start justify-between mb-4">
          <span class="text-prof-red text-xs font-bold tracking-[0.15em] uppercase px-3 py-1 bg-prof-red/5 rounded-full" style="font-family: 'Figtree', sans-serif;">Annual</span>
        </div>
        <h3 class="text-2xl text-prof-text mb-3" style="font-family: 'Playfair Display', serif; font-weight: 700;">GIC Hack Day</h3>
        <p class="text-prof-secondary leading-relaxed mb-4" style="font-family: 'Figtree', sans-serif;">
          24 hours. Teams of 2-4. Build something from scratch. All skill levels welcome — designers, coders, project managers, and people who just want to learn. Prizes and pizza included.
        </p>
        <span class="text-prof-muted text-sm" style="font-family: 'Figtree', sans-serif;">November &middot; Nathan Campus</span>
      </div>

      <!-- Industry Night -->
      <div class="reveal border border-prof-border rounded-2xl p-8 hover:shadow-lg hover:shadow-prof-dark/5 transition-all duration-300 group">
        <div class="flex items-start justify-between mb-4">
          <span class="text-prof-red text-xs font-bold tracking-[0.15em] uppercase px-3 py-1 bg-prof-red/5 rounded-full" style="font-family: 'Figtree', sans-serif;">Trimesterly</span>
        </div>
        <h3 class="text-2xl text-prof-text mb-3" style="font-family: 'Playfair Display', serif; font-weight: 700;">Industry Night</h3>
        <p class="text-prof-secondary leading-relaxed mb-4" style="font-family: 'Figtree', sans-serif;">
          An evening with companies hiring in tech. Hear what they actually look for, ask questions, and make connections that lead to internships and grad roles.
        </p>
        <span class="text-prof-muted text-sm" style="font-family: 'Figtree', sans-serif;">Once per trimester &middot; Both campuses</span>
      </div>

      <!-- Workshop Series -->
