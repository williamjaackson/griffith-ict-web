<%# ═══════════════════════════════════════════════════════════
    ABOUT — asymmetric two-column with pull quote
    ═══════════════════════════════════════════════════════════ %>
<section id="about" class="py-24 md:py-32">
  <div class="max-w-6xl mx-auto px-6">
    <div class="grid md:grid-cols-12 gap-12 md:gap-16 items-start">
      <!-- Pull quote -->
      <div class="md:col-span-5 reveal">
        <span class="text-prof-red text-xs font-semibold tracking-[0.2em] uppercase block mb-6" style="font-family: 'Figtree', sans-serif;">Who We Are</span>
        <blockquote class="text-3xl md:text-4xl text-prof-text leading-snug" style="font-family: 'Playfair Display', serif; font-weight: 600;">
          &ldquo;We're not just a club that runs events. We're a community of students who help each other learn, land internships, survive assignments, and build things that matter.&rdquo;
        </blockquote>
        <div class="w-16 h-1 bg-prof-red mt-8"></div>
      </div>

      <!-- Body text -->
      <div class="md:col-span-7 reveal" style="font-family: 'Figtree', sans-serif;">
        <p class="text-prof-secondary text-lg leading-relaxed mb-6">
          GIC (Griffith ICT Club) is a student-run organisation for anyone at Griffith University interested in technology — whether that's software engineering, cybersecurity, data science, UX design, or just figuring out what you want to do with your career.
        </p>
        <p class="text-prof-secondary text-lg leading-relaxed mb-6">
          We operate across <strong class="text-prof-text font-semibold">Nathan</strong> (Brisbane / Meanjin) and <strong class="text-prof-text font-semibold">Gold Coast</strong> (Yugambeh) campuses, running everything from hands-on technical workshops to industry networking nights, hackathons, and regular social hangouts.
        </p>
        <p class="text-prof-secondary text-lg leading-relaxed mb-8">
          Whether you're in your first trimester or finishing honours, studying IT or arts — there's a place for you here. Membership is free, and you don't need any experience to get involved.
        </p>
        <div class="flex flex-wrap gap-3">
          <span class="inline-flex items-center gap-1.5 bg-prof-surface border border-prof-border text-prof-text text-sm font-medium px-4 py-1.5 rounded-full">
            <svg class="w-3.5 h-3.5 text-prof-red" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            Open to all degrees
          </span>
          <span class="inline-flex items-center gap-1.5 bg-prof-surface border border-prof-border text-prof-text text-sm font-medium px-4 py-1.5 rounded-full">
            <svg class="w-3.5 h-3.5 text-prof-red" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            Free membership
          </span>
          <span class="inline-flex items-center gap-1.5 bg-prof-surface border border-prof-border text-prof-text text-sm font-medium px-4 py-1.5 rounded-full">
            <svg class="w-3.5 h-3.5 text-prof-red" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            No experience needed
          </span>
          <span class="inline-flex items-center gap-1.5 bg-prof-surface border border-prof-border text-prof-text text-sm font-medium px-4 py-1.5 rounded-full">
            <svg class="w-3.5 h-3.5 text-prof-red" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            Two campuses
          </span>
        </div>
      </div>
    </div>
  </div>
</section>

<%# ═══════════════════════════════════════════════════════════
    WHAT WE DO — 4 pillars on stone background
    ═══════════════════════════════════════════════════════════ %>
<section id="pillars" class="py-24 md:py-32 bg-prof-surface">
  <div class="max-w-6xl mx-auto px-6">
    <div class="max-w-xl mb-16 reveal">
      <span class="text-prof-red text-xs font-semibold tracking-[0.2em] uppercase block mb-4" style="font-family: 'Figtree', sans-serif;">What We Do</span>
      <h2 class="text-3xl md:text-4xl text-prof-text leading-tight" style="font-family: 'Playfair Display', serif; font-weight: 700;">
        Four pillars of our community
      </h2>
    </div>

    <div class="grid md:grid-cols-2 gap-6">
      <!-- Learn -->
      <div class="reveal bg-white rounded-2xl p-8 md:p-10 border border-prof-border/50 hover:border-prof-red/30 transition-colors duration-300 group">
        <div class="w-12 h-12 bg-prof-red/10 rounded-xl flex items-center justify-center mb-6 group-hover:bg-prof-red/20 transition-colors duration-300">
          <svg class="w-6 h-6 text-prof-red" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.636 50.636 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 7.74-3.342M6.75 15a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm0 0v-3.675A55.378 55.378 0 0 1 12 8.443m-7.007 11.55A5.981 5.981 0 0 0 6.75 15.75v-1.5"/></svg>
        </div>
        <h3 class="text-xl text-prof-text font-bold mb-3" style="font-family: 'Playfair Display', serif;">Learn</h3>
        <p class="text-prof-secondary leading-relaxed" style="font-family: 'Figtree', sans-serif;">
          Hands-on workshops covering web dev, cloud, AI, cybersecurity, Git, and more. Led by students, for students. No prerequisites — just show up.
        </p>
      </div>

      <!-- Build -->
      <div class="reveal bg-white rounded-2xl p-8 md:p-10 border border-prof-border/50 hover:border-prof-red/30 transition-colors duration-300 group">
        <div class="w-12 h-12 bg-prof-red/10 rounded-xl flex items-center justify-center mb-6 group-hover:bg-prof-red/20 transition-colors duration-300">
          <svg class="w-6 h-6 text-prof-red" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17 17.25 21A2.652 2.652 0 0 0 21 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 1 1-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 0 0 4.486-6.336l-3.276 3.277a3.004 3.004 0 0 1-2.25-2.25l3.276-3.276a4.5 4.5 0 0 0-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085m-1.745 1.437L5.909 7.5H4.5L2.25 3.75l1.5-1.5L7.5 4.5v1.409l4.26 4.26m-1.745 1.437 1.745-1.437m6.615 8.206L15.75 15.75M4.867 19.125h.008v.008h-.008v-.008Z"/></svg>
        </div>
        <h3 class="text-xl text-prof-text font-bold mb-3" style="font-family: 'Playfair Display', serif;">Build</h3>
        <p class="text-prof-secondary leading-relaxed" style="font-family: 'Figtree', sans-serif;">
          Hackathons, group projects, and open-source contributions. We build real things — from weekend prototypes to tools that Griffith students actually use.
        </p>
      </div>

      <!-- Connect -->
      <div class="reveal bg-white rounded-2xl p-8 md:p-10 border border-prof-border/50 hover:border-prof-red/30 transition-colors duration-300 group">
        <div class="w-12 h-12 bg-prof-red/10 rounded-xl flex items-center justify-center mb-6 group-hover:bg-prof-red/20 transition-colors duration-300">
          <svg class="w-6 h-6 text-prof-red" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M20.25 14.15v4.25c0 1.094-.787 2.036-1.872 2.18-2.087.277-4.216.42-6.378.42s-4.291-.143-6.378-.42c-1.085-.144-1.872-1.086-1.872-2.18v-4.25m16.5 0a2.18 2.18 0 0 0 .75-1.661V8.706c0-1.081-.768-2.015-1.837-2.175a48.114 48.114 0 0 0-3.413-.387m4.5 8.006c-.194.165-.42.295-.673.38A23.978 23.978 0 0 1 12 15.75c-2.648 0-5.195-.429-7.577-1.22a2.016 2.016 0 0 1-.673-.38m0 0A2.18 2.18 0 0 1 3 12.489V8.706c0-1.081.768-2.015 1.837-2.175a48.111 48.111 0 0 1 3.413-.387m7.5 0V5.25A2.25 2.25 0 0 0 13.5 3h-3a2.25 2.25 0 0 0-2.25 2.25v.894m7.5 0a48.667 48.667 0 0 0-7.5 0M12 12.75h.008v.008H12v-.008Z"/></svg>
        </div>
        <h3 class="text-xl text-prof-text font-bold mb-3" style="font-family: 'Playfair Display', serif;">Connect</h3>
        <p class="text-prof-secondary leading-relaxed" style="font-family: 'Figtree', sans-serif;">
          Industry nights, resume reviews, mock interviews, and sponsor events. Meet the companies hiring grads in Brisbane and the Gold Coast.
        </p>
      </div>

      <!-- Hang Out -->
      <div class="reveal bg-white rounded-2xl p-8 md:p-10 border border-prof-border/50 hover:border-prof-red/30 transition-colors duration-300 group">
        <div class="w-12 h-12 bg-prof-red/10 rounded-xl flex items-center justify-center mb-6 group-hover:bg-prof-red/20 transition-colors duration-300">
          <svg class="w-6 h-6 text-prof-red" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.182 15.182a4.5 4.5 0 0 1-6.364 0M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0ZM9.75 9.75c0 .414-.168.75-.375.75S9 10.164 9 9.75 9.168 9 9.375 9s.375.336.375.75Zm-.375 0h.008v.015h-.008V9.75Zm5.625 0c0 .414-.168.75-.375.75s-.375-.336-.375-.75.168-.75.375-.75.375.336.375.75Zm-.375 0h.008v.015h-.008V9.75Z"/></svg>
        </div>
        <h3 class="text-xl text-prof-text font-bold mb-3" style="font-family: 'Playfair Display', serif;">Hang Out</h3>
        <p class="text-prof-secondary leading-relaxed" style="font-family: 'Figtree', sans-serif;">
          Weekly Tech & Chill sessions, game nights, BBQs, trivia, and end-of-trimester parties. We're a community first, a club second.
        </p>
      </div>
    </div>
