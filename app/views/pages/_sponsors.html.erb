<section id="sponsors" class="py-24 md:py-32 px-6 border-t-3 border-brand-black" style="background-color: #F0EBE3;">
  <div class="max-w-6xl mx-auto">
    <div class="mb-16">
      <%= ui_badge("OUR PARTNERS", class: "rotate-2 mb-4") %>
      <%= ui_heading("Backed by industry.", level: 2) %>
      <p class="text-brand-gray text-lg max-w-2xl leading-relaxed">
        We partner with companies who believe in supporting the next generation of tech talent.
        Sponsors help us run bigger events, better hackathons, and provide real-world opportunities for our members.
      </p>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-5">
      <div class="flex items-center justify-center h-24 bg-white border-3 border-dashed border-brand-black/30 text-brand-gray/40 text-sm font-bold">Your logo here</div>
      <div class="flex items-center justify-center h-24 bg-white border-3 border-dashed border-brand-black/30 text-brand-gray/40 text-sm font-bold">Your logo here</div>
      <div class="flex items-center justify-center h-24 bg-white border-3 border-dashed border-brand-black/30 text-brand-gray/40 text-sm font-bold">Your logo here</div>
      <%= ui_card(color: "#D32F2F", class: "grid place-items-center", href: "#sponsors") do %>
        <p class="text-white font-bold">Sponsor Us &rarr;</p>
      <% end %>
    </div>
  </div>
</section>
