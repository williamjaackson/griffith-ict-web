<section class="py-24 md:py-32 px-6 border-t-3 border-brand-black" data-controller="animation">
  <div class="max-w-6xl mx-auto">
    <div class="mb-16 reveal">
      <h2 class="heading">Why sponsor us?</h2>
      <p class="text-brand-gray text-lg max-w-2xl leading-relaxed">
        We're the largest tech club at Griffith. Here's what you get access to.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 reveal stagger">
      <div>
        <div class="card" style="box-shadow: 5px 5px 0px var(--color-brand-red-300);">
          <div class="w-10 h-10 bg-brand-red/10 flex items-center justify-center mb-4">
            <%= lucide_icon("users", class: "w-5 h-5 text-brand-red") %>
          </div>
          <h3 class="heading"><%= Rails.application.config.meta[:member_count] %> members</h3>
          <p class="text-brand-gray text-sm leading-relaxed">
            Engaged students across software, cybersecurity, data science, and IT. These are your future hires.
          </p>
        </div>
      </div>

      <div>
        <div class="card" style="box-shadow: 5px 5px 0px var(--color-brand-red-dark);">
          <div class="w-10 h-10 bg-brand-red/10 flex items-center justify-center mb-4">
            <%= lucide_icon("calendar", class: "w-5 h-5 text-brand-red") %>
          </div>
          <h3 class="heading">Weekly events</h3>
          <p class="text-brand-gray text-sm leading-relaxed">
            Workshops, hackathons, game nights, and industry panels. Consistent touchpoints with students all year round.
          </p>
        </div>
      </div>

      <div>
        <div class="card" style="box-shadow: 5px 5px 0px var(--color-brand-red);">
          <div class="w-10 h-10 bg-brand-red/10 flex items-center justify-center mb-4">
            <%= lucide_icon("map-pin", class: "w-5 h-5 text-brand-red") %>
          </div>
          <h3 class="heading">2 campuses</h3>
          <p class="text-brand-gray text-sm leading-relaxed">
            Presence on Griffith's two largest campuses: Gold Coast and Nathan. Reaching students all across Queensland.
          </p>
        </div>
      </div>

      <div>
        <div class="card" style="box-shadow: 5px 5px 0px var(--color-brand-red-200);">
          <div class="w-10 h-10 bg-brand-red/10 flex items-center justify-center mb-4">
            <%= lucide_icon("monitor", class: "w-5 h-5 text-brand-red") %>
          </div>
          <h3 class="heading">Real visibility</h3>
          <p class="text-brand-gray text-sm leading-relaxed">
            Your brand on our website, socials, Discord, and at every event we run. Consistent, visible placement wherever we show up.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
