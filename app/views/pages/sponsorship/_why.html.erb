<section class="py-24 md:py-32 px-6 border-t-3 border-brand-black" data-controller="reveal">
  <div class="max-w-6xl mx-auto">
    <div class="mb-16 reveal-up" data-reveal-target="item">
      <%= ui_heading("Why sponsor us?", level: 2) %>
      <p class="text-brand-gray text-lg max-w-2xl leading-relaxed">
        We're the largest tech club at Griffith. Here's what you get access to.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
      <div class="reveal-up" data-reveal-target="item" style="transition-delay: 100ms;">
        <%= ui_card(shadow: "var(--color-brand-red-300)") do %>
          <div class="w-10 h-10 bg-brand-red/10 flex items-center justify-center mb-4">
            <%= lucide_icon("users", class: "w-5 h-5 text-brand-red") %>
          </div>
          <%= ui_heading("400+ members", level: 3) %>
          <p class="text-brand-gray text-sm leading-relaxed">
            Engaged students across software, cybersecurity, data science, and IT. These are your future hires.
          </p>
        <% end %>
      </div>

      <div class="reveal-up" data-reveal-target="item" style="transition-delay: 200ms;">
        <%= ui_card(shadow: "var(--color-brand-red-dark)") do %>
          <div class="w-10 h-10 bg-brand-red/10 flex items-center justify-center mb-4">
            <%= lucide_icon("calendar", class: "w-5 h-5 text-brand-red") %>
          </div>
          <%= ui_heading("Weekly events", level: 3) %>
          <p class="text-brand-gray text-sm leading-relaxed">
            Workshops, hackathons, game nights, and industry panels. Consistent touchpoints with students all year round.
          </p>
        <% end %>
      </div>

      <div class="reveal-up" data-reveal-target="item" style="transition-delay: 300ms;">
        <%= ui_card(shadow: "var(--color-brand-red)") do %>
          <div class="w-10 h-10 bg-brand-red/10 flex items-center justify-center mb-4">
            <%= lucide_icon("map-pin", class: "w-5 h-5 text-brand-red") %>
          </div>
          <%= ui_heading("2 campuses", level: 3) %>
          <p class="text-brand-gray text-sm leading-relaxed">
            Presence on Griffith's two largest campuses: Gold Coast and Nathan. Reaching students all across Queensland.
          </p>
        <% end %>
      </div>

      <div class="reveal-up" data-reveal-target="item" style="transition-delay: 400ms;">
        <%= ui_card(shadow: "var(--color-brand-red-200)") do %>
          <div class="w-10 h-10 bg-brand-red/10 flex items-center justify-center mb-4">
            <%= lucide_icon("monitor", class: "w-5 h-5 text-brand-red") %>
          </div>
          <%= ui_heading("Real visibility", level: 3) %>
          <p class="text-brand-gray text-sm leading-relaxed">
            Your brand on our website, socials, Discord, and at every event we run. Consistent, visible placement wherever we show up.
          </p>
        <% end %>
      </div>
    </div>
  </div>
</section>
