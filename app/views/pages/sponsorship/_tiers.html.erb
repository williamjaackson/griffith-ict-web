<section class="py-24 md:py-32 px-6 border-t-3 border-brand-black bg-brand-cream" data-controller="reveal">
  <div class="max-w-6xl mx-auto">
    <div class="mb-16 reveal-up" data-reveal-target="item">
      <%= ui_heading("Sponsorship tiers.", level: 2) %>
      <p class="text-brand-gray text-lg max-w-2xl leading-relaxed">
        Each tier builds on the one before it. Pick the level that fits your goals and budget.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 items-start">
      <% accumulated_perks = [] %>
      <% @tiers.each_with_index do |tier, i| %>
        <% tier_key = tier["name"].downcase %>
        <div class="reveal-up" data-reveal-target="item" style="transition-delay: <%= (i + 1) * 100 %>ms;">
          <%= ui_card(sidebar: tier["color"], class: tier["rotation"]) do %>
            <%= ui_badge(tier["name"].upcase, size: :sm, color: tier["color"]) %>
            <p class="text-2xl font-extrabold text-brand-black mt-3" style="font-family: 'Unbounded', sans-serif;"><%= tier["price"] %></p>
            <p class="text-brand-gray text-sm mt-4 mb-6 leading-relaxed"><%= tier["description"] %></p>
            <ul class="flex flex-col gap-3 text-sm">
              <% accumulated_perks.each do |perk| %>
                <li class="flex items-start gap-2 text-brand-gray">
                  <span class="font-bold mt-0.5" style="color: var(--color-tier-<%= perk[:tier] %>);">&#10003;</span>
                  <%= perk[:label] %>
                </li>
              <% end %>
              <% tier["perks"].each do |perk| %>
                <li class="flex items-start gap-2 text-brand-gray">
                  <span class="font-bold mt-0.5" style="color: var(--color-tier-<%= tier_key %>);">&#10003;</span>
                  <%= perk %>
                </li>
              <% end %>
            </ul>
          <% end %>
        </div>
        <% tier["perks"].each { |p| accumulated_perks << { label: p, tier: tier_key } } %>
      <% end %>
    </div>
  </div>
</section>
