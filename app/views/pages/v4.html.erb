<%# ═══════════════════════════════════════════════════════════
    HERO — Terminal session
    ═══════════════════════════════════════════════════════════ %>
<header class="min-h-screen flex items-center justify-center px-6 pt-20 pb-16">
  <div class="max-w-3xl w-full">
    <%# Terminal window chrome %>
    <div class="animate-fade-up bg-navy-900 border border-navy-800 rounded-lg overflow-hidden shadow-2xl">
      <%# Title bar %>
      <div class="flex items-center gap-2 px-4 py-3 bg-navy-800/50 border-b border-navy-800">
        <span class="w-3 h-3 rounded-full bg-[#FF5F56]"></span>
        <span class="w-3 h-3 rounded-full bg-[#FFBD2E]"></span>
        <span class="w-3 h-3 rounded-full bg-[#27C93F]"></span>
        <span class="text-terminal-muted text-xs ml-3" style="font-family: 'JetBrains Mono', monospace;">gic@griffith: ~</span>
      </div>

      <%# Terminal content %>
      <div class="p-6 md:p-8" style="font-family: 'JetBrains Mono', monospace;">
        <div class="space-y-2 mb-8">
          <p class="text-sm md:text-base"><span class="text-terminal-green">$</span> <span class="text-terminal-text">./welcome --club gic</span></p>
          <p class="text-terminal-cyan text-sm md:text-base">&gt; Griffith ICT Club</p>
          <p class="text-terminal-cyan text-sm md:text-base">&gt; Build. Learn. Connect.</p>
          <p class="text-terminal-muted text-sm md:text-base">&gt; An inclusive community of students passionate about technology.</p>
          <p class="text-sm md:text-base mt-4"><span class="text-terminal-green">$</span> <span class="text-terminal-text">cat stats.json</span></p>
          <p class="text-terminal-yellow text-sm md:text-base">{ "members": "200+", "events_per_year": "50+", "campuses": 2 }</p>
          <p class="text-sm md:text-base mt-4"><span class="text-terminal-green">$</span> <span class="text-terminal-text">join --discord</span></p>
          <p class="text-terminal-muted text-sm md:text-base">&gt; Opening invite link...</p>
        </div>

        <div class="flex flex-col sm:flex-row gap-3 border-t border-navy-800 pt-6">
          <a href="#community" class="inline-flex items-center gap-2 bg-terminal-green text-navy-950 font-semibold px-6 py-3 rounded text-sm transition-all duration-200 hover:brightness-110">
            $ join --discord
          </a>
          <a href="#about" class="inline-flex items-center gap-2 border border-navy-700 text-terminal-text hover:border-terminal-muted px-6 py-3 rounded text-sm transition-all duration-200">
            $ cat README.md
          </a>
        </div>
      </div>
    </div>

    <%# Scroll hint %>
    <div class="flex justify-center mt-10 animate-fade-up-3">
      <span class="text-terminal-muted text-xs tracking-widest" style="font-family: 'JetBrains Mono', monospace;">// scroll for more</span>
    </div>
  </div>
</header>

<%# ═══════════════════════════════════════════════════════════
    ABOUT
    ═══════════════════════════════════════════════════════════ %>
<section id="about" class="py-24 md:py-32 px-6">
  <div class="max-w-5xl mx-auto">
    <span class="reveal block text-terminal-green text-sm mb-6" style="font-family: 'JetBrains Mono', monospace;">// ABOUT</span>
    <h2 class="reveal text-3xl md:text-5xl text-white font-bold mb-6" style="font-family: 'Manrope', sans-serif;">By students, for students.</h2>
    <p class="reveal text-terminal-muted text-lg max-w-3xl leading-relaxed mb-16" style="font-family: 'Manrope', sans-serif;">
      GIC is Griffith University's ICT club, based across Nathan (Brisbane / Meanjin)
      and Gold Coast (Yugambeh) campuses. We exist to help students build skills,
      make friends, and kickstart their careers in tech.
    </p>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
      <div class="reveal bg-navy-900 border border-navy-800 rounded-lg overflow-hidden transition-all duration-300 hover:border-navy-700">
        <div class="flex items-center gap-2 px-4 py-2 border-b border-navy-800">
          <span class="w-2 h-2 rounded-full bg-[#FF5F56]"></span>
          <span class="w-2 h-2 rounded-full bg-[#FFBD2E]"></span>
          <span class="w-2 h-2 rounded-full bg-[#27C93F]"></span>
        </div>
        <div class="p-5">
          <span class="text-terminal-green text-xs mb-3 block" style="font-family: 'JetBrains Mono', monospace;">--workshop</span>
          <h3 class="text-white font-semibold text-base mb-2" style="font-family: 'Manrope', sans-serif;">Workshops</h3>
          <p class="text-terminal-muted text-sm leading-relaxed" style="font-family: 'Manrope', sans-serif;">
            Hands-on sessions covering web dev, cloud, AI, cybersecurity, and more.
          </p>
        </div>
      </div>

      <div class="reveal bg-navy-900 border border-navy-800 rounded-lg overflow-hidden transition-all duration-300 hover:border-navy-700">
        <div class="flex items-center gap-2 px-4 py-2 border-b border-navy-800">
          <span class="w-2 h-2 rounded-full bg-[#FF5F56]"></span>
          <span class="w-2 h-2 rounded-full bg-[#FFBD2E]"></span>
          <span class="w-2 h-2 rounded-full bg-[#27C93F]"></span>
        </div>
        <div class="p-5">
          <span class="text-terminal-yellow text-xs mb-3 block" style="font-family: 'JetBrains Mono', monospace;">--hackathon</span>
          <h3 class="text-white font-semibold text-base mb-2" style="font-family: 'Manrope', sans-serif;">Hackathons</h3>
          <p class="text-terminal-muted text-sm leading-relaxed" style="font-family: 'Manrope', sans-serif;">
            Team up, ship fast, win prizes. We run our own and send teams to nationals.
          </p>
        </div>
      </div>

      <div class="reveal bg-navy-900 border border-navy-800 rounded-lg overflow-hidden transition-all duration-300 hover:border-navy-700">
        <div class="flex items-center gap-2 px-4 py-2 border-b border-navy-800">
          <span class="w-2 h-2 rounded-full bg-[#FF5F56]"></span>
          <span class="w-2 h-2 rounded-full bg-[#FFBD2E]"></span>
          <span class="w-2 h-2 rounded-full bg-[#27C93F]"></span>
        </div>
        <div class="p-5">
          <span class="text-terminal-cyan text-xs mb-3 block" style="font-family: 'JetBrains Mono', monospace;">--social</span>
          <h3 class="text-white font-semibold text-base mb-2" style="font-family: 'Manrope', sans-serif;">Social Events</h3>
          <p class="text-terminal-muted text-sm leading-relaxed" style="font-family: 'Manrope', sans-serif;">
            Game nights, BBQs, trivia, and casual hangouts. Meet your people.
          </p>
        </div>
      </div>

      <div class="reveal bg-navy-900 border border-navy-800 rounded-lg overflow-hidden transition-all duration-300 hover:border-navy-700">
        <div class="flex items-center gap-2 px-4 py-2 border-b border-navy-800">
          <span class="w-2 h-2 rounded-full bg-[#FF5F56]"></span>
          <span class="w-2 h-2 rounded-full bg-[#FFBD2E]"></span>
          <span class="w-2 h-2 rounded-full bg-[#27C93F]"></span>
        </div>
        <div class="p-5">
          <span class="text-red-400 text-xs mb-3 block" style="font-family: 'JetBrains Mono', monospace;">--industry</span>
          <h3 class="text-white font-semibold text-base mb-2" style="font-family: 'Manrope', sans-serif;">Industry Nights</h3>
          <p class="text-terminal-muted text-sm leading-relaxed" style="font-family: 'Manrope', sans-serif;">
            Connect with companies hiring grads. Get your foot in the door early.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

