<%# ═══════════════════════════════════════════════════════════
    HERO — Split layout
    ═══════════════════════════════════════════════════════════ %>
<header class="relative min-h-screen flex items-center px-6 overflow-hidden">
  <div class="max-w-7xl mx-auto w-full grid grid-cols-1 lg:grid-cols-5 gap-12 lg:gap-8 items-center pt-24 lg:pt-0">
    <%# Left column — text %>
    <div class="lg:col-span-3 relative z-10">
      <p class="animate-fade-up text-red-500 font-medium text-sm tracking-widest uppercase mb-6">
        Griffith University's student tech community
      </p>

      <h1 class="animate-fade-up-1 text-5xl sm:text-6xl md:text-7xl text-ink leading-[0.95] mb-8" style="font-family: 'Fraunces', serif; font-weight: 900; font-variation-settings: 'WONK' 1;">
        Build. Learn.<br>
        <span class="relative inline-block">
          Connect.
          <span class="absolute bottom-1 left-0 right-0 h-3 bg-red-100 -z-10 rounded-sm"></span>
        </span>
      </h1>

      <p class="animate-fade-up-2 text-ink-light text-lg md:text-xl max-w-xl leading-relaxed mb-10">
        We're an inclusive community of students passionate about technology.
        Whether you're writing your first line of code or deploying to production,
        there's a place for you here.
      </p>

      <div class="animate-fade-up-3 flex flex-col sm:flex-row items-start gap-4 mb-16">
        <a href="#community" class="bg-red-500 hover:bg-red-600 text-white font-semibold px-8 py-3.5 rounded-full transition-all duration-200 hover:scale-105 hover:shadow-lg text-base">
          Join our Discord
        </a>
        <a href="#about" class="border border-border hover:border-ink-lighter text-ink font-medium px-8 py-3.5 rounded-full transition-all duration-200 hover:bg-cream-dark text-base">
          Learn more
        </a>
      </div>

      <div class="animate-fade-up-4 flex items-center gap-8 md:gap-14">
        <div>
          <span class="block text-2xl md:text-3xl text-red-500" style="font-family: 'Fraunces', serif; font-weight: 800;">200+</span>
          <span class="text-ink-lighter text-sm font-medium">Members</span>
        </div>
        <div class="w-px h-10 bg-border"></div>
        <div>
          <span class="block text-2xl md:text-3xl text-red-500" style="font-family: 'Fraunces', serif; font-weight: 800;">50+</span>
          <span class="text-ink-lighter text-sm font-medium">Events / year</span>
        </div>
        <div class="w-px h-10 bg-border"></div>
        <div>
          <span class="block text-2xl md:text-3xl text-red-500" style="font-family: 'Fraunces', serif; font-weight: 800;">2</span>
          <span class="text-ink-lighter text-sm font-medium">Campuses</span>
        </div>
      </div>
    </div>

    <%# Right column — giant GIC typography %>
    <div class="hidden lg:flex lg:col-span-2 items-center justify-end overflow-hidden select-none" aria-hidden="true">
      <span class="text-[20rem] xl:text-[24rem] leading-none text-red-500/10 tracking-tighter" style="font-family: 'Fraunces', serif; font-weight: 900; font-variation-settings: 'WONK' 1;">
        GIC
      </span>
    </div>
  </div>
</header>

<%# ═══════════════════════════════════════════════════════════
    ABOUT — Left-aligned with red accent bar
    ═══════════════════════════════════════════════════════════ %>
<section id="about" class="py-24 md:py-32 px-6 bg-cream-dark">
  <div class="max-w-6xl mx-auto">
    <div class="reveal flex items-start gap-4 mb-6">
      <div class="w-1 h-16 bg-red-500 rounded-full shrink-0 mt-1"></div>
      <div>
        <span class="block text-red-500 font-semibold text-sm tracking-widest uppercase mb-2">What we do</span>
        <h2 class="text-3xl md:text-5xl text-ink" style="font-family: 'Fraunces', serif; font-weight: 800;">By students, for students.</h2>
      </div>
    </div>
    <p class="reveal text-ink-light text-lg md:text-xl max-w-3xl leading-relaxed mb-16 ml-5">
      GIC is Griffith University's ICT club, based across Nathan (Brisbane / Meanjin)
      and Gold Coast (Yugambeh) campuses. We exist to help students build skills,
      make friends, and kickstart their careers in tech — no matter their experience level.
    </p>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
      <div class="reveal group relative bg-cream border border-border rounded-2xl p-8 transition-all duration-300 hover:-translate-y-1 hover:shadow-md overflow-hidden">
        <span class="absolute -top-4 -right-2 text-8xl font-bold text-red-50 select-none pointer-events-none" style="font-family: 'Fraunces', serif; font-weight: 900;">01</span>
        <div class="relative">
          <div class="w-12 h-12 bg-cream-dark rounded-xl flex items-center justify-center text-2xl mb-4">&#x1F4BB;</div>
          <h3 class="text-lg text-ink font-semibold mb-2" style="font-family: 'Fraunces', serif; font-weight: 700;">Workshops</h3>
          <p class="text-ink-light text-sm leading-relaxed">
            Hands-on sessions covering web dev, cloud, AI, cybersecurity, and more.
            Learn by building real things with people who get it.
          </p>
        </div>
      </div>

      <div class="reveal group relative bg-cream border border-border rounded-2xl p-8 transition-all duration-300 hover:-translate-y-1 hover:shadow-md overflow-hidden">
        <span class="absolute -top-4 -right-2 text-8xl font-bold text-red-50 select-none pointer-events-none" style="font-family: 'Fraunces', serif; font-weight: 900;">02</span>
        <div class="relative">
          <div class="w-12 h-12 bg-cream-dark rounded-xl flex items-center justify-center text-2xl mb-4">&#x1F3C6;</div>
          <h3 class="text-lg text-ink font-semibold mb-2" style="font-family: 'Fraunces', serif; font-weight: 700;">Hackathons</h3>
          <p class="text-ink-light text-sm leading-relaxed">
            Team up, ship fast, win prizes. We run our own hackathons and send teams
            to national competitions.
          </p>
        </div>
      </div>

      <div class="reveal group relative bg-cream border border-border rounded-2xl p-8 transition-all duration-300 hover:-translate-y-1 hover:shadow-md overflow-hidden">
        <span class="absolute -top-4 -right-2 text-8xl font-bold text-red-50 select-none pointer-events-none" style="font-family: 'Fraunces', serif; font-weight: 900;">03</span>
        <div class="relative">
          <div class="w-12 h-12 bg-cream-dark rounded-xl flex items-center justify-center text-2xl mb-4">&#x1F37B;</div>
          <h3 class="text-lg text-ink font-semibold mb-2" style="font-family: 'Fraunces', serif; font-weight: 700;">Social Events</h3>
          <p class="text-ink-light text-sm leading-relaxed">
            Game nights, BBQs, trivia, and casual hangouts. The best part of uni
            is the people — we make sure you meet them.
          </p>
        </div>
      </div>

      <div class="reveal group relative bg-cream border border-border rounded-2xl p-8 transition-all duration-300 hover:-translate-y-1 hover:shadow-md overflow-hidden">
        <span class="absolute -top-4 -right-2 text-8xl font-bold text-red-50 select-none pointer-events-none" style="font-family: 'Fraunces', serif; font-weight: 900;">04</span>
        <div class="relative">
          <div class="w-12 h-12 bg-cream-dark rounded-xl flex items-center justify-center text-2xl mb-4">&#x1F454;</div>
          <h3 class="text-lg text-ink font-semibold mb-2" style="font-family: 'Fraunces', serif; font-weight: 700;">Industry Nights</h3>
          <p class="text-ink-light text-sm leading-relaxed">
            Connect with companies hiring grads. Hear from engineers, ask questions,
            and get your foot in the door before you graduate.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<%# ═══════════════════════════════════════════════════════════
    EVENTS — Vertical cards, middle offset
    ═══════════════════════════════════════════════════════════ %>
<section id="events" class="py-24 md:py-32 px-6">
  <div class="max-w-6xl mx-auto">
    <div class="reveal flex items-start gap-4 mb-6">
      <div class="w-1 h-16 bg-red-500 rounded-full shrink-0 mt-1"></div>
      <div>
        <span class="block text-red-500 font-semibold text-sm tracking-widest uppercase mb-2">Upcoming</span>
        <h2 class="text-3xl md:text-5xl text-ink" style="font-family: 'Fraunces', serif; font-weight: 800;">What's happening next</h2>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mt-16">
      <%# Event 1: Workshop %>
      <article class="reveal bg-white border border-border rounded-2xl overflow-hidden transition-all duration-300 hover:-translate-y-1 hover:shadow-md">
        <div class="h-1 bg-red-500"></div>
        <div class="p-6">
          <div class="mb-4">
            <span class="text-5xl text-ink" style="font-family: 'Fraunces', serif; font-weight: 800;">12</span>
            <span class="block text-ink-lighter text-xs font-semibold uppercase tracking-wider">March 2026</span>
          </div>
          <span class="inline-block bg-red-50 text-red-600 border border-red-100 text-xs font-semibold px-3 py-1 rounded-full mb-3">Workshop</span>
          <h3 class="text-lg text-ink font-semibold mb-2" style="font-family: 'Fraunces', serif; font-weight: 700;">Intro to Git & GitHub</h3>
          <p class="text-ink-light text-sm leading-relaxed mb-4">
            Never used version control? No worries. We'll walk through everything
            from your first commit to opening a pull request.
          </p>
          <div class="flex flex-wrap gap-3 text-ink-lighter text-xs font-medium">
            <span class="flex items-center gap-1.5">
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6l4 2"/><circle cx="12" cy="12" r="10"/></svg>
              6:00 PM
            </span>
            <span class="flex items-center gap-1.5">
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              Nathan, N44
            </span>
          </div>
        </div>
      </article>

      <%# Event 2: Social — offset up on desktop %>
      <article class="reveal bg-white border border-border rounded-2xl overflow-hidden transition-all duration-300 hover:-translate-y-1 hover:shadow-md md:-translate-y-6">
        <div class="h-1 bg-emerald-500"></div>
        <div class="p-6">
          <div class="mb-4">
            <span class="text-5xl text-ink" style="font-family: 'Fraunces', serif; font-weight: 800;">19</span>
            <span class="block text-ink-lighter text-xs font-semibold uppercase tracking-wider">March 2026</span>
          </div>
          <span class="inline-block bg-emerald-50 text-emerald-700 border border-emerald-100 text-xs font-semibold px-3 py-1 rounded-full mb-3">Social</span>
          <h3 class="text-lg text-ink font-semibold mb-2" style="font-family: 'Fraunces', serif; font-weight: 700;">Welcome Week BBQ</h3>
          <p class="text-ink-light text-sm leading-relaxed mb-4">
            Kick off the semester with free food, lawn games, and good vibes.
            Bring your mates or come solo — everyone's welcome.
          </p>
          <div class="flex flex-wrap gap-3 text-ink-lighter text-xs font-medium">
            <span class="flex items-center gap-1.5">
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6l4 2"/><circle cx="12" cy="12" r="10"/></svg>
              12:00 PM
            </span>
            <span class="flex items-center gap-1.5">
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              Gold Coast, G40
            </span>
          </div>
        </div>
      </article>

      <%# Event 3: Hackathon %>
      <article class="reveal bg-white border border-border rounded-2xl overflow-hidden transition-all duration-300 hover:-translate-y-1 hover:shadow-md">
        <div class="h-1 bg-violet-500"></div>
        <div class="p-6">
          <div class="mb-4">
            <span class="text-5xl text-ink" style="font-family: 'Fraunces', serif; font-weight: 800;">02</span>
            <span class="block text-ink-lighter text-xs font-semibold uppercase tracking-wider">April 2026</span>
          </div>
          <span class="inline-block bg-violet-50 text-violet-700 border border-violet-100 text-xs font-semibold px-3 py-1 rounded-full mb-3">Hackathon</span>
          <h3 class="text-lg text-ink font-semibold mb-2" style="font-family: 'Fraunces', serif; font-weight: 700;">GIC Hack Day 2026</h3>
          <p class="text-ink-light text-sm leading-relaxed mb-4">
            24 hours. One idea. Ship something awesome. Teams of 2–4, all skill
            levels, with prizes and pizza.
          </p>
          <div class="flex flex-wrap gap-3 text-ink-lighter text-xs font-medium">
            <span class="flex items-center gap-1.5">
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6l4 2"/><circle cx="12" cy="12" r="10"/></svg>
              9:00 AM – 9:00 AM
            </span>
            <span class="flex items-center gap-1.5">
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              Nathan, N78
            </span>
          </div>
        </div>
      </article>
    </div>

    <div class="reveal text-center mt-12">
      <a href="#community" class="inline-flex items-center gap-2 border border-border hover:border-ink-lighter text-ink font-medium px-6 py-3 rounded-full transition-all duration-200 hover:bg-cream-dark text-sm">
        See all events on Discord
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
    </div>
  </div>
</section>

<%# ═══════════════════════════════════════════════════════════
    COMMUNITY — Discord emphasized
    ═══════════════════════════════════════════════════════════ %>
<section id="community" class="py-24 md:py-32 px-6 bg-cream-dark">
  <div class="max-w-6xl mx-auto">
    <div class="reveal flex items-start gap-4 mb-6">
      <div class="w-1 h-16 bg-red-500 rounded-full shrink-0 mt-1"></div>
      <div>
        <span class="block text-red-500 font-semibold text-sm tracking-widest uppercase mb-2">Get involved</span>
        <h2 class="text-3xl md:text-5xl text-ink" style="font-family: 'Fraunces', serif; font-weight: 800;">Find us everywhere</h2>
