        <div class="absolute top-0 left-0 w-1 h-full bg-ink rounded-l-2xl"></div>
        <div class="pl-3">
          <div class="text-ink mb-4">
            <svg viewBox="0 0 24 24" fill="currentColor" class="w-8 h-8"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
          </div>
          <h3 class="text-lg text-ink font-semibold mb-1" style="font-family: 'Fraunces', serif; font-weight: 700;">GitHub</h3>
          <p class="text-ink-light text-sm">Open source projects and workshop code.</p>
        </div>
      </a>

      <%# LinkedIn %>
      <a href="https://linkedin.com/company/griffith-ict-club" target="_blank" rel="noopener" class="reveal group bg-cream border border-border rounded-2xl p-6 transition-all duration-300 hover:-translate-y-1 hover:shadow-md block relative overflow-hidden">
