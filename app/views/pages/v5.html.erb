<%# ═══════════════════════════════════════════════════════════
    HERO — Bold shapes + overlap
    ═══════════════════════════════════════════════════════════ %>
<header class="relative min-h-screen flex items-center overflow-hidden px-6 pt-20 pb-16">
  <%# Large decorative red shape — partially cropped by viewport %>
  <div class="absolute top-[-10%] right-[-8%] w-[500px] h-[600px] md:w-[700px] md:h-[800px] bg-red-500 rounded-[60px] -rotate-12 opacity-90 pointer-events-none"></div>
  <%# Small decorative circle %>
  <div class="absolute bottom-[15%] left-[5%] w-24 h-24 md:w-32 md:h-32 bg-red-500 rounded-full opacity-20 pointer-events-none"></div>
  <%# Another accent shape %>
  <div class="absolute top-[60%] right-[15%] w-16 h-16 bg-red-500 rounded-2xl opacity-15 rotate-12 pointer-events-none"></div>

  <div class="relative z-10 max-w-7xl mx-auto w-full">
    <div class="max-w-3xl">
      <p class="animate-fade-up text-red-500 font-bold text-sm tracking-widest uppercase mb-6" style="font-family: 'Nunito', sans-serif;">
        Griffith University's student tech community
      </p>

      <h1 class="animate-fade-up-1 text-5xl sm:text-6xl md:text-7xl lg:text-[6rem] text-campus-dark leading-[0.95] mb-8" style="font-family: 'Sora', sans-serif; font-weight: 800;">
        Build. Learn.<br>
        <span class="text-red-500">Connect.</span>
      </h1>

      <p class="animate-fade-up-2 text-campus-gray text-lg md:text-xl max-w-xl leading-relaxed mb-10" style="font-family: 'Nunito', sans-serif;">
        We're an inclusive community of students passionate about technology.
        Whether you're writing your first line of code or deploying to production,
        there's a place for you here.
      </p>

      <div class="animate-fade-up-3 flex flex-col sm:flex-row items-start gap-4 mb-16">
        <a href="#community" class="bg-red-500 hover:bg-red-600 text-white font-bold px-8 py-4 rounded-full transition-all duration-200 hover:scale-105 hover:shadow-xl text-base" style="font-family: 'Sora', sans-serif;">
          Join our Discord
        </a>
        <a href="#about" class="border-2 border-campus-dark/20 hover:border-campus-dark text-campus-dark font-semibold px-8 py-4 rounded-full transition-all duration-200 text-base" style="font-family: 'Sora', sans-serif;">
          Learn more
        </a>
      </div>

      <div class="animate-fade-up-4 flex items-center gap-10 md:gap-16">
        <div>
          <span class="block text-3xl md:text-4xl text-campus-dark font-extrabold" style="font-family: 'Sora', sans-serif;">200+</span>
          <div class="w-10 h-1 bg-red-500 rounded-full mt-2 mb-1"></div>
          <span class="text-campus-gray text-sm font-medium" style="font-family: 'Nunito', sans-serif;">Members</span>
        </div>
        <div>
          <span class="block text-3xl md:text-4xl text-campus-dark font-extrabold" style="font-family: 'Sora', sans-serif;">50+</span>
          <div class="w-10 h-1 bg-red-500 rounded-full mt-2 mb-1"></div>
          <span class="text-campus-gray text-sm font-medium" style="font-family: 'Nunito', sans-serif;">Events / year</span>
        </div>
        <div>
          <span class="block text-3xl md:text-4xl text-campus-dark font-extrabold" style="font-family: 'Sora', sans-serif;">2</span>
          <div class="w-10 h-1 bg-red-500 rounded-full mt-2 mb-1"></div>
          <span class="text-campus-gray text-sm font-medium" style="font-family: 'Nunito', sans-serif;">Campuses</span>
        </div>
      </div>
    </div>
  </div>
</header>

<%# ═══════════════════════════════════════════════════════════
    ABOUT
    ═══════════════════════════════════════════════════════════ %>
<section id="about" class="py-24 md:py-32 px-6 bg-campus-light">
  <div class="max-w-6xl mx-auto">
    <span class="reveal block text-red-500 font-bold text-sm tracking-widest uppercase mb-4" style="font-family: 'Nunito', sans-serif;">What we do</span>
    <h2 class="reveal text-3xl md:text-5xl text-campus-dark font-extrabold mb-6" style="font-family: 'Sora', sans-serif;">By students, for students.</h2>
    <p class="reveal text-campus-gray text-lg max-w-3xl leading-relaxed mb-16" style="font-family: 'Nunito', sans-serif;">
      GIC is Griffith University's ICT club, based across Nathan (Brisbane / Meanjin)
      and Gold Coast (Yugambeh) campuses. We exist to help students build skills,
      make friends, and kickstart their careers in tech.
    </p>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      <div class="reveal bg-white rounded-2xl p-7 border-l-[6px] border-red-500 shadow-sm transition-all duration-300 hover:-rotate-1 hover:shadow-lg">
        <div class="text-3xl mb-4">&#x1F4BB;</div>
        <h3 class="text-campus-dark font-bold text-lg mb-2" style="font-family: 'Sora', sans-serif;">Workshops</h3>
        <p class="text-campus-gray text-sm leading-relaxed" style="font-family: 'Nunito', sans-serif;">
          Hands-on sessions covering web dev, cloud, AI, cybersecurity, and more.
        </p>
      </div>

      <div class="reveal bg-white rounded-2xl p-7 border-l-[6px] border-red-500 shadow-sm transition-all duration-300 hover:rotate-1 hover:shadow-lg">
        <div class="text-3xl mb-4">&#x1F3C6;</div>
        <h3 class="text-campus-dark font-bold text-lg mb-2" style="font-family: 'Sora', sans-serif;">Hackathons</h3>
        <p class="text-campus-gray text-sm leading-relaxed" style="font-family: 'Nunito', sans-serif;">
          Team up, ship fast, win prizes. We run our own and send teams to nationals.
        </p>
      </div>

      <div class="reveal bg-white rounded-2xl p-7 border-l-[6px] border-red-500 shadow-sm transition-all duration-300 hover:-rotate-1 hover:shadow-lg">
        <div class="text-3xl mb-4">&#x1F37B;</div>
        <h3 class="text-campus-dark font-bold text-lg mb-2" style="font-family: 'Sora', sans-serif;">Social Events</h3>
        <p class="text-campus-gray text-sm leading-relaxed" style="font-family: 'Nunito', sans-serif;">
          Game nights, BBQs, trivia, and casual hangouts. Meet your people.
        </p>
      </div>

      <div class="reveal bg-white rounded-2xl p-7 border-l-[6px] border-red-500 shadow-sm transition-all duration-300 hover:rotate-1 hover:shadow-lg">
        <div class="text-3xl mb-4">&#x1F454;</div>
        <h3 class="text-campus-dark font-bold text-lg mb-2" style="font-family: 'Sora', sans-serif;">Industry Nights</h3>
        <p class="text-campus-gray text-sm leading-relaxed" style="font-family: 'Nunito', sans-serif;">
          Connect with companies hiring grads. Get your foot in the door early.
        </p>
      </div>
    </div>
  </div>
</section>

<%# ═══════════════════════════════════════════════════════════
    EVENTS — Timeline layout
    ═══════════════════════════════════════════════════════════ %>
<section id="events" class="py-24 md:py-32 px-6">
  <div class="max-w-6xl mx-auto">
    <span class="reveal block text-red-500 font-bold text-sm tracking-widest uppercase mb-4" style="font-family: 'Nunito', sans-serif;">Upcoming</span>
    <h2 class="reveal text-3xl md:text-5xl text-campus-dark font-extrabold mb-16" style="font-family: 'Sora', sans-serif;">What's happening next</h2>

    <%# Timeline %>
    <div class="relative">
      <%# Vertical red line %>
      <div class="absolute left-6 md:left-8 top-0 bottom-0 w-0.5 bg-red-500/30"></div>

      <div class="flex flex-col gap-12">
        <%# Event 1 %>
        <article class="reveal relative pl-16 md:pl-20">
          <%# Timeline dot %>
          <div class="absolute left-[18px] md:left-[26px] top-1 w-4 h-4 bg-red-500 rounded-full border-4 border-white shadow-sm"></div>
          <div class="flex flex-col sm:flex-row sm:items-start gap-4">
            <div class="shrink-0">
              <span class="inline-block bg-red-500 text-white text-xs font-bold px-3 py-1.5 rounded-full" style="font-family: 'Sora', sans-serif;">12 MAR</span>
            </div>
            <div class="flex-1 bg-white rounded-2xl p-6 shadow-sm border border-gray-100">
              <span class="inline-block bg-red-50 text-red-500 border border-red-100 text-xs font-bold px-2.5 py-0.5 rounded-full mb-3" style="font-family: 'Nunito', sans-serif;">Workshop</span>
              <h3 class="text-campus-dark font-bold text-lg mb-2" style="font-family: 'Sora', sans-serif;">Intro to Git & GitHub</h3>
              <p class="text-campus-gray text-sm leading-relaxed mb-3" style="font-family: 'Nunito', sans-serif;">
                From your first commit to opening a pull request. All levels welcome.
              </p>
              <div class="flex flex-wrap gap-4 text-campus-gray/70 text-xs font-medium" style="font-family: 'Nunito', sans-serif;">
                <span>6:00 PM</span>
                <span>Nathan Campus, N44</span>
              </div>
            </div>
          </div>
        </article>

        <%# Event 2 %>
        <article class="reveal relative pl-16 md:pl-20">
          <div class="absolute left-[18px] md:left-[26px] top-1 w-4 h-4 bg-red-500 rounded-full border-4 border-white shadow-sm"></div>
          <div class="flex flex-col sm:flex-row sm:items-start gap-4">
            <div class="shrink-0">
              <span class="inline-block bg-red-500 text-white text-xs font-bold px-3 py-1.5 rounded-full" style="font-family: 'Sora', sans-serif;">19 MAR</span>
            </div>
            <div class="flex-1 bg-white rounded-2xl p-6 shadow-sm border border-gray-100">
              <span class="inline-block bg-emerald-50 text-emerald-600 border border-emerald-100 text-xs font-bold px-2.5 py-0.5 rounded-full mb-3" style="font-family: 'Nunito', sans-serif;">Social</span>
              <h3 class="text-campus-dark font-bold text-lg mb-2" style="font-family: 'Sora', sans-serif;">Welcome Week BBQ</h3>
              <p class="text-campus-gray text-sm leading-relaxed mb-3" style="font-family: 'Nunito', sans-serif;">
                Free food, lawn games, and good vibes. Bring your mates or come solo.
              </p>
              <div class="flex flex-wrap gap-4 text-campus-gray/70 text-xs font-medium" style="font-family: 'Nunito', sans-serif;">
                <span>12:00 PM</span>
                <span>Gold Coast Campus, G40 Lawn</span>
              </div>
            </div>
          </div>
        </article>

        <%# Event 3 %>
        <article class="reveal relative pl-16 md:pl-20">
          <div class="absolute left-[18px] md:left-[26px] top-1 w-4 h-4 bg-red-500 rounded-full border-4 border-white shadow-sm"></div>
          <div class="flex flex-col sm:flex-row sm:items-start gap-4">
            <div class="shrink-0">
              <span class="inline-block bg-red-500 text-white text-xs font-bold px-3 py-1.5 rounded-full" style="font-family: 'Sora', sans-serif;">02 APR</span>
            </div>
            <div class="flex-1 bg-white rounded-2xl p-6 shadow-sm border border-gray-100">
              <span class="inline-block bg-violet-50 text-violet-600 border border-violet-100 text-xs font-bold px-2.5 py-0.5 rounded-full mb-3" style="font-family: 'Nunito', sans-serif;">Hackathon</span>
              <h3 class="text-campus-dark font-bold text-lg mb-2" style="font-family: 'Sora', sans-serif;">GIC Hack Day 2026</h3>
              <p class="text-campus-gray text-sm leading-relaxed mb-3" style="font-family: 'Nunito', sans-serif;">
                24 hours. One idea. Ship something awesome. Teams of 2–4, all skill levels.
              </p>
              <div class="flex flex-wrap gap-4 text-campus-gray/70 text-xs font-medium" style="font-family: 'Nunito', sans-serif;">
                <span>9:00 AM – 9:00 AM</span>
                <span>Nathan Campus, N78</span>
              </div>
            </div>
          </div>
        </article>
      </div>
    </div>

    <div class="reveal text-center mt-14">
      <a href="#community" class="inline-flex items-center gap-2 border-2 border-campus-dark/20 hover:border-campus-dark text-campus-dark font-semibold px-6 py-3 rounded-full transition-all duration-200 text-sm" style="font-family: 'Sora', sans-serif;">
        See all events on Discord
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
    </div>
  </div>
</section>

