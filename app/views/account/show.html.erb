<header>
  <div class="container enter stagger">
    <span class="badge -rotate-2 mb-8"><%= current_user.role.upcase %></span>
    <h1 class="heading heading-1">Your <span class="heading-highlight">account.</span></h1>
    <p class="text-lg md:text-xl max-w-2xl mb-10">
      Signed in as <span class="text-brand-black font-semibold"><%= current_user.email_address %></span>
    </p>
    <div class="flex flex-wrap gap-4">
      <%= button_to "Sign out", session_path, method: :delete, class: "btn btn-primary" %>
      <a href="/" class="btn btn-secondary">Back to home</a>
    </div>
    <% if current_user.admin? %>
      <%= link_to admin_invites_path, class: "text-brand-red font-semibold hover:underline inline-flex items-center gap-1" do %>Manage invites <%= icon "arrow-right", class: "w-4 h-4" %><% end %>
    <% end %>
  </div>
</header>
