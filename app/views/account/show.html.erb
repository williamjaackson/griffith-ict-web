<section class="px-6 py-24 md:py-32">
  <div class="max-w-md mx-auto">
    <div class="mb-8">
      <%= ui_heading("Your account.", level: 2, highlight: "account.") %>
    </div>

    <div class="bg-white border-3 border-brand-black p-8 shadow-[6px_6px_0px_var(--color-brand-black)]">
      <div class="space-y-5">
        <div>
          <p class="text-sm font-semibold text-brand-black mb-1">Email</p>
          <p class="text-brand-gray"><%= current_user.email_address %></p>
        </div>

        <div>
          <p class="text-sm font-semibold text-brand-black mb-1">Role</p>
          <%= ui_badge(current_user.role.capitalize, size: :sm) %>
        </div>

        <% if current_user.admin? %>
          <div class="pt-3 border-t-2 border-brand-cream">
            <%= link_to "Manage invites", admin_invites_path, class: "text-sm font-semibold text-brand-red hover:underline" %>
          </div>
        <% end %>

        <div class="pt-3 border-t-2 border-brand-cream">
          <%= button_to "Sign out", session_path, method: :delete, class: "inline-flex items-center justify-center text-center font-bold border-3 border-brand-black cursor-pointer transition-all duration-200 hover:-translate-y-1 active:translate-y-0 active:shadow-none bg-white text-brand-black px-5 py-2.5 text-sm hover:shadow-[5px_5px_0px_var(--color-brand-red)]", style: "font-family: 'Unbounded', sans-serif; font-weight: 600;" %>
        </div>
      </div>
    </div>
  </div>
</section>
