<style>
  @keyframes hero-in {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-hero-in { animation: hero-in 0.4s cubic-bezier(0.2, 0, 0, 1) both; }
</style>

<header class="px-6 pt-8 pb-24">
  <div class="max-w-6xl mx-auto">
    <div class="animate-hero-in">
      <span class="badge -rotate-2 mb-8"><%= current_user.role.upcase %></span>
    </div>
    <div class="animate-hero-in" style="animation-delay: 100ms;">
      <h1 class="heading">Your <span class="heading-highlight">account.</span></h1>
    </div>
    <p class="animate-hero-in text-brand-gray text-lg md:text-xl max-w-2xl leading-relaxed mb-10" style="animation-delay: 200ms;">
      Signed in as <span class="text-brand-black font-semibold"><%= current_user.email_address %></span>
    </p>
    <div class="animate-hero-in flex flex-wrap gap-4" style="animation-delay: 300ms;">
      <%= button_to "Sign out", session_path, method: :delete, class: "btn btn-primary" %>
      <a href="/" class="btn btn-secondary">Back to home</a>
    </div>
  </div>
</header>

<% if current_user.admin? %>
  <section class="px-6 pb-24 animate-hero-in" style="animation-delay: 400ms;">
    <div class="max-w-6xl mx-auto">
      <%= link_to "Manage invites →", admin_invites_path, class: "text-brand-red font-semibold hover:underline" %>
    </div>
  </section>
<% end %>
