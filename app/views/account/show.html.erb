<style>
  @keyframes hero-in {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-hero-in { animation: hero-in 0.4s cubic-bezier(0.2, 0, 0, 1) both; }
</style>

<header class="px-6 pt-8 pb-24">
  <div class="max-w-6xl mx-auto">
    <div class="animate-hero-in">
      <%= ui_badge(current_user.role.upcase, class: "-rotate-2 mb-8") %>
    </div>
    <div class="animate-hero-in" style="animation-delay: 100ms;">
      <%= ui_heading("Your account.", level: 1, highlight: "account.") %>
    </div>
    <p class="animate-hero-in text-brand-gray text-lg md:text-xl max-w-2xl leading-relaxed mb-10" style="animation-delay: 200ms;">
      Signed in as <span class="text-brand-black font-semibold"><%= current_user.email_address %></span>
    </p>
    <div class="animate-hero-in flex flex-wrap gap-4" style="animation-delay: 300ms;">
      <%= button_to "Sign out", session_path, method: :delete, class: "inline-flex items-center justify-center text-center font-bold border-3 border-brand-black cursor-pointer transition-all duration-200 hover:-translate-y-1 active:translate-y-0 active:shadow-none bg-white text-brand-black px-8 py-4 text-base hover:shadow-[5px_5px_0px_var(--color-brand-red)]", style: "font-family: 'Unbounded', sans-serif; font-weight: 600;" %>
      <%= ui_button("Back to home", href: "/", variant: :secondary) %>
    </div>
  </div>
</header>

<% if current_user.admin? %>
  <section class="px-6 pb-24">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-5 animate-hero-in" style="animation-delay: 400ms;">
        <%= ui_card(href: admin_invites_path, sidebar: "var(--color-brand-red)") do %>
          <h3 class="text-lg font-bold text-brand-black mb-1" style="font-family: 'Unbounded', sans-serif;">Invites</h3>
          <p class="text-brand-gray text-sm">Manage staff invitations</p>
        <% end %>
      </div>
    </div>
  </section>
<% end %>
