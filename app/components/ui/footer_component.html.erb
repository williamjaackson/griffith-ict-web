<footer class="bg-brand-black border-t-3 border-brand-black pt-16 pb-8 px-6">
  <div class="max-w-6xl mx-auto">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-12 mb-16">
      <div class="col-span-2">
        <div class="mb-4">
          <%= helpers.ui_logo(type: :full, class: "h-6 brightness-0 invert") %>
        </div>
        <p class="text-white/40 text-sm leading-relaxed max-w-sm">
          Made with questionable amounts of caffeine by students who should probably be studying.
          You've scrolled this far? Honestly, we didn't think you'd read this.
          Go join the Discord already.
        </p>
      </div>

      <% link_groups.each do |group| %>
        <div>
          <h4 class="text-brand-red font-bold text-sm mb-4" style="font-family: 'Unbounded', sans-serif; font-weight: 600;"><%= group[:title] %></h4>
          <ul class="flex flex-col gap-3">
            <% group[:links].each do |link| %>
              <li>
                <a href="<%= link[:href] %>" class="text-white/50 hover:text-white transition-colors text-sm"><%= link[:label] %></a>
              </li>
            <% end %>
          </ul>
        </div>
      <% end %>
    </div>

    <div class="border-t border-white/10 pt-8 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-white/30 text-xs">&copy; <%= year %> Griffith ICT Club. Built by students.</p>
      <a href="https://www.griffith.edu.au" target="_blank" rel="noopener" class="text-white/30 hover:text-white/50 transition-colors text-xs">Griffith University</a>
    </div>
  </div>
</footer>
