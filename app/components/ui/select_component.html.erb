<div data-controller="select" class="relative">
  <input type="hidden" name="<%= @name %>" value="<%= selected_option[:value] %>" data-select-target="input">

  <button type="button" data-select-target="button" data-action="select#toggle"
          class="block w-full rounded-md border-2 border-brand-cream bg-brand-bg focus:outline-none focus:border-brand-red px-3 py-2.5 text-left cursor-pointer flex items-center justify-between">
    <span data-role="label"><%= selected_option[:label] %></span>
    <svg data-select-target="chevron" class="w-4 h-4 text-brand-gray transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
    </svg>
  </button>

  <div data-select-target="menu" class="absolute top-full left-0 right-0 mt-1 z-10 opacity-0 pointer-events-none scale-95 transition-all duration-200 origin-top">
    <div class="bg-brand-bg border-3 border-brand-black shadow-[4px_4px_0px_var(--color-brand-black)]">
      <% @options.each do |option| %>
        <button type="button" data-action="select#pick" data-value="<%= option[:value] %>" data-label="<%= option[:label] %>"
                class="block w-full text-left px-4 py-3 text-sm font-semibold text-brand-gray hover:text-brand-black hover:bg-brand-cream transition-colors duration-150 border-b-3 border-brand-black last:border-b-0 cursor-pointer">
          <%= option[:label] %>
        </button>
      <% end %>
    </div>
  </div>
</div>
