<%= tag.div id: id,
            data: dialog_data,
            aria: { hidden: true },
            inert: true,
            class: "fixed inset-0 z-50 bg-brand-black/50 flex items-center justify-center px-6 opacity-0 pointer-events-none transition-opacity duration-300" do %>
  <%= tag.div data: { modal_target: "panel" },
              role: "dialog",
              aria: dialog_aria,
              tabindex: -1,
              class: panel_classes do %>
    <button type="button"
            data-action="modal#close"
            aria-label="Close modal"
            class="absolute top-4 right-4 p-2 text-brand-gray hover:text-brand-black transition-colors cursor-pointer focus-visible:outline-3 focus-visible:outline-brand-red">
      <%= helpers.icon "x", class: "w-5 h-5", stroke_width: "2.5" %>
    </button>

    <% if title %>
      <h2 id="<%= title_id %>" class="heading heading-3"><%= title %></h2>
    <% end %>

    <%= content %>
  <% end %>
<% end %>
