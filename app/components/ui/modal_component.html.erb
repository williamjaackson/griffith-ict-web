<%= tag.div data: wrapper_data do %>
  <%# Backdrop %>
  <%= tag.div data: backdrop_data,
              class: "fixed inset-0 z-50 bg-brand-black/50 flex items-center justify-center px-6 opacity-0 pointer-events-none transition-opacity duration-300" do %>

    <%# Panel %>
    <%= tag.div data: panel_data,
                class: "bg-brand-bg border-3 border-brand-black shadow-[6px_6px_0px_var(--color-brand-black)] w-full max-w-md p-8 scale-95 opacity-0 transition-all duration-300" do %>

      <% if title %>
        <h2 class="heading !text-2xl !mb-2"><%= title %></h2>
      <% end %>

      <%= content %>
    <% end %>
  <% end %>
<% end %>
