<nav data-controller="navbar" class="bg-brand-bg fixed top-0 left-0 right-0 z-50 transition-all duration-300">
  <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between relative z-20">
    <a href="/#" class="flex items-center gap-3 group">
      <%= helpers.ui_logo %>
    </a>

    <%= render Ui::Navbar::DesktopComponent.new(links: links, cta: cta) %>

    <button data-navbar-target="toggle" data-action="navbar#toggleMenu" class="hamburger md:hidden flex flex-col gap-1.5 cursor-pointer relative z-20" aria-label="Toggle navigation">
      <span class="block w-6 h-0.5 bg-brand-black rounded-full transition-transform duration-300 origin-center"></span>
      <span class="block w-6 h-0.5 bg-brand-black rounded-full transition-opacity duration-300"></span>
      <span class="block w-6 h-0.5 bg-brand-black rounded-full transition-transform duration-300 origin-center"></span>
    </button>
  </div>

  <%= render Ui::Navbar::MobileComponent.new(links: links, cta: cta) %>
</nav>
