<nav data-controller="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
  <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between relative z-20">
    <a href="/" class="flex items-center gap-3 group">
      <%= helpers.ui_logo %>
    </a>

    <%# Desktop nav %>
    <ul class="hidden md:flex items-center gap-8">
      <% links.each do |link| %>
        <li>
          <% if link[:children] %>
            <div data-controller="dropdown" data-action="mouseenter->dropdown#show mouseleave->dropdown#hide focusin->dropdown#show focusout->dropdown#hide" class="relative">
              <a href="<%= link[:href] %>" class="relative text-brand-gray hover:text-brand-black transition-colors duration-200 text-sm font-semibold group inline-flex items-center gap-1">
                <%= link[:label] %>
                <%= chevron_svg %>
                <span class="absolute -bottom-1 left-1/2 w-0 h-0.5 bg-brand-red transition-all duration-300 group-hover:w-full group-hover:left-0"></span>
              </a>
              <div data-dropdown-target="menu" class="absolute top-full left-1/2 -translate-x-1/2 pt-3 opacity-0 pointer-events-none scale-95 transition-all duration-200 origin-top">
                <div class="bg-brand-bg border-3 border-brand-black shadow-[4px_4px_0px_var(--color-brand-black)] min-w-48">
                  <% link[:children].each do |child| %>
                    <a href="<%= child[:href] %>" class="block px-5 py-3 text-sm font-semibold text-brand-gray hover:text-brand-black hover:bg-brand-cream transition-colors duration-150 border-b-3 border-brand-black last:border-b-0">
                      <%= child[:label] %>
                    </a>
                  <% end %>
                </div>
              </div>
            </div>
          <% else %>
            <a href="<%= link[:href] %>" class="relative text-brand-gray hover:text-brand-black transition-colors duration-200 text-sm font-semibold group">
              <%= link[:label] %>
              <span class="absolute -bottom-1 left-1/2 w-0 h-0.5 bg-brand-red transition-all duration-300 group-hover:w-full group-hover:left-0"></span>
            </a>
          <% end %>
        </li>
      <% end %>
    </ul>

    <div class="hidden md:block">
      <%= helpers.ui_button(cta[:label], href: cta[:href], variant: :primary, size: :sm) %>
    </div>

    <button data-navbar-target="toggle" data-action="navbar#toggleMenu" class="hamburger md:hidden flex flex-col gap-1.5 cursor-pointer relative z-20" aria-label="Toggle navigation">
      <span class="block w-6 h-0.5 bg-brand-black transition-transform duration-300 origin-center"></span>
      <span class="block w-6 h-0.5 bg-brand-black transition-opacity duration-300"></span>
      <span class="block w-6 h-0.5 bg-brand-black transition-transform duration-300 origin-center"></span>
    </button>
  </div>

  <%# Mobile menu %>
  <div data-navbar-target="menu" class="fixed inset-0 z-10 flex flex-col items-center justify-center gap-8 bg-brand-bg font-unbounded opacity-0 pointer-events-none transition-all duration-500 md:hidden">
    <% links.each do |link| %>
      <% if link[:children] %>
        <div data-controller="dropdown" data-dropdown-variant-value="mobile" class="flex flex-col items-center">
          <button data-action="dropdown#toggle" class="text-2xl font-bold text-brand-black hover:text-brand-red transition-colors inline-flex items-center gap-2 cursor-pointer">
            <%= link[:label] %>
            <%= chevron_svg(size: "w-5 h-5", data: { dropdown_target: "chevron" }) %>
          </button>
          <div data-dropdown-target="menu" class="grid grid-rows-[0fr] transition-[grid-template-rows,opacity] duration-300 opacity-0">
            <div class="overflow-hidden flex flex-col items-center pt-2">
              <% link[:children].each do |child| %>
                <a href="<%= child[:href] %>" class="text-lg font-bold text-brand-gray hover:text-brand-red transition-colors py-2" data-action="navbar#closeMenu">
                  <%= child[:label] %>
                </a>
              <% end %>
            </div>
          </div>
        </div>
      <% else %>
        <a href="<%= link[:href] %>" class="text-2xl font-bold text-brand-black hover:text-brand-red transition-colors" data-action="navbar#closeMenu">
          <%= link[:label] %>
        </a>
      <% end %>
    <% end %>
    <%= helpers.ui_button(cta[:label], href: cta[:href], variant: :primary) %>
  </div>
</nav>
