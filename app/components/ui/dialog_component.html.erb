<%= tag.dialog(**attributes) do %>
  <div class="dialog-panel" tabindex="-1" data-dialog-panel>
    <button type="button" class="dialog-close" data-action="dialog#close" aria-label="Close dialog">
      <%= helpers.icon "x", class: "w-5 h-5" %>
    </button>
    <% if title %>
      <h2 id="<%= title_id %>" class="heading heading-3"><%= title %></h2>
    <% end %>
    <%= content %>
  </div>
<% end %>
