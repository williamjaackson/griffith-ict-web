<nav aria-label="Primary" data-controller="navbar" data-action="keydown@window->navbar#keydown" class="bg-brand-bg fixed top-0 left-0 right-0 z-50 transition-all duration-300">
  <div class="container px-6 py-4 flex items-center justify-between relative z-20">
    <a href="<%= helpers.root_path %>" class="flex items-center gap-3 group">
      <%= image_tag "/logo/GriffithICTClubIcon.svg", alt: "Griffith ICT Club", class: "h-8 w-auto", draggable: "false" %>
    </a>

    <%= render Site::Navbar::DesktopComponent.new(links: links, cta: cta) %>

    <button type="button"
            data-navbar-target="toggle"
            data-action="navbar#toggleMenu"
            class="hamburger md:hidden cursor-pointer relative z-20 text-brand-black"
            aria-label="Toggle navigation"
            aria-controls="mobile-navigation"
            aria-expanded="false">
      <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <path d="M4 12h16" />
        <path d="M4 12h16" />
        <path d="M4 12h16" />
      </svg>
    </button>
  </div>

  <%= render Site::Navbar::MobileComponent.new(links: links, cta: cta) %>
</nav>
