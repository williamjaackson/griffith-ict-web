<nav data-controller="navbar" class="bg-brand-bg fixed top-0 left-0 right-0 z-50 transition-all duration-300">
  <div class="container px-6 py-4 flex items-center justify-between relative z-20">
    <a href="/#" class="flex items-center gap-3 group">
      <%= image_tag "/logo/GriffithICTClubIcon.svg", alt: "Griffith ICT Club", class: "h-8 w-auto", draggable: "false" %>
    </a>

    <%= render Site::Navbar::DesktopComponent.new(links: links, cta: cta) %>

    <button data-navbar-target="toggle" data-action="navbar#toggleMenu" class="hamburger md:hidden cursor-pointer relative z-20 text-brand-black" aria-label="Toggle navigation">
      <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <path d="M4 12h16" />
        <path d="M4 12h16" />
        <path d="M4 12h16" />
      </svg>
    </button>
  </div>

  <%= render Site::Navbar::MobileComponent.new(links: links, cta: cta) %>

  <% if featured_event %>
    <div class="event-announcement bg-brand-red text-white">
      <%= link_to helpers.event_path(featured_event.slug), class: "flex flex-wrap items-center justify-center gap-x-2 px-4 py-2 text-center text-xs sm:text-sm font-bold text-white hover:text-white" do %>
        <span class="font-extrabold">AI HACKATHON:</span>
        <span><%= featured_event.local_starts_at.strftime("%-d %B %Y") %></span>
        <span class="underline underline-offset-2">RSVP now →</span>
      <% end %>
    </div>
  <% end %>
</nav>
