<ul class="hidden md:flex items-center gap-8">
  <% links.each do |link| %>
    <li>
      <% if link[:children] %>
        <div data-controller="dropdown" data-action="mouseenter->dropdown#show mouseleave->dropdown#hide focusin->dropdown#show focusout->dropdown#hide keydown->dropdown#keydown" class="relative">
          <a href="<%= link[:href] %>"
             data-dropdown-target="trigger"
             aria-haspopup="true"
             aria-expanded="false"
             aria-controls="<%= dropdown_id(link) %>"
             class="relative hover:text-brand-black transition-colors duration-200 text-sm font-semibold group inline-flex items-center gap-1">
            <%= link[:label] %>
            <%= helpers.icon "chevron-down", class: "w-3.5 h-3.5 transition-transform duration-200", stroke_width: "2.5", data: { dropdown_target: "chevron" } %>
            <%= underline_span %>
          </a>
          <div id="<%= dropdown_id(link) %>"
               data-dropdown-target="menu"
               aria-hidden="true"
               inert
               class="absolute top-full left-1/2 -translate-x-1/2 pt-3 opacity-0 pointer-events-none scale-95 transition-all duration-200 origin-top">
            <div class="bg-brand-bg border-3 border-brand-black shadow-[4px_4px_0px_var(--color-brand-black)] min-w-48">
              <% link[:children].each do |child| %>
                <a href="<%= child[:href] %>" class="block px-5 py-3 text-sm font-semibold hover:text-brand-black hover:bg-brand-cream transition-colors duration-150 border-b-3 border-brand-black last:border-b-0">
                  <%= child[:label] %>
                </a>
              <% end %>
            </div>
          </div>
        </div>
      <% else %>
        <a href="<%= link[:href] %>" class="relative hover:text-brand-black transition-colors duration-200 text-sm font-semibold group">
          <%= link[:label] %>
          <%= underline_span %>
        </a>
      <% end %>
    </li>
  <% end %>
</ul>

<div class="hidden md:block">
  <% if helpers.authenticated? %>
    <a href="<%= helpers.account_path %>" class="btn btn-secondary btn-sm">Account</a>
  <% else %>
    <%= helpers.button_tag cta[:label],
          type: "button",
          class: "btn btn-primary btn-sm",
          data: Ui::ModalComponent.trigger_data(Site::MembershipModalComponent::ID) %>
  <% end %>
</div>
