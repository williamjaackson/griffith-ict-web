<div class="card <%= tier.fetch(:rotation) %>">
  <div class="absolute left-0 top-0 bottom-0 w-3" style="background-color: <%= tier.fetch(:color) %>;"></div>
  <span class="badge badge-sm" style="background-color: <%= tier.fetch(:color) %>;"><%= tier.fetch(:name).upcase %></span>
  <p class="text-2xl font-extrabold text-brand-black mt-3 heading"><%= tier.fetch(:price) %></p>
  <p class="text-sm mt-4 mb-6"><%= tier.fetch(:description) %></p>
  <ul class="flex flex-col gap-3 text-sm">
    <% perks.each do |perk| %>
      <li class="flex items-start gap-2">
        <span class="mt-0.5 shrink-0" style="color: var(--color-tier-<%= perk.fetch(:tier) %>);">
          <%= helpers.icon "check", class: "w-4 h-4", stroke_width: "3" %>
        </span>
        <%= perk.fetch(:label) %>
      </li>
    <% end %>
  </ul>
</div>
