<footer class="bg-brand-black border-t-3 border-brand-black pt-16 pb-8 px-6">
  <div class="container">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-12 mb-16">
      <div class="col-span-2">
        <div class="mb-4">
          <%= image_tag "/logo/GriffithICTClubLogo.svg", alt: "Griffith ICT Club", class: "h-6 w-auto brightness-0 invert", draggable: "false" %>
        </div>
        <p class="text-white/40 text-sm max-w-sm mb-5">
          Made with questionable amounts of caffeine by students who should probably be studying.
          You've scrolled this far? Honestly, we didn't think you'd read this.
          Go join the Discord already.
        </p>
        <div class="flex items-center gap-4">
          <a href="<%= socials[:discord] %>" target="_blank" rel="noopener" class="text-white/40 hover:text-white transition-colors" aria-label="Discord">
            <%= helpers.icon"discord", library: "brands" %>
          </a>
          <a href="<%= socials[:github] %>" target="_blank" rel="noopener" class="text-white/40 hover:text-white transition-colors" aria-label="GitHub">
            <%= helpers.icon"github", library: "brands" %>
          </a>
          <a href="<%= socials[:linkedin] %>" target="_blank" rel="noopener" class="text-white/40 hover:text-white transition-colors" aria-label="LinkedIn">
            <%= helpers.icon"linkedin", library: "brands" %>
          </a>
          <a href="<%= socials[:instagram] %>" target="_blank" rel="noopener" class="text-white/40 hover:text-white transition-colors" aria-label="Instagram">
            <%= helpers.icon"instagram", library: "brands" %>
          </a>
        </div>
      </div>

      <% link_groups.each do |group| %>
        <div>
          <p class="heading heading-5 text-brand-red"><%= group[:title] %></p>
          <ul class="flex flex-col gap-3">
            <% group[:links].each do |link| %>
              <li>
                <a href="<%= link[:href] %>" class="text-white/50 hover:text-white transition-colors text-sm"><%= link[:label] %></a>
              </li>
            <% end %>
          </ul>
        </div>
      <% end %>
    </div>

    <div class="border-t border-white/10 pt-8 flex flex-col sm:flex-row items-center justify-between gap-4 relative">
      <p class="text-white/30 text-xs">&copy; <%= year %> Griffith ICT Club. By students.</p>
      <div class="flex items-center gap-4 text-white/30 text-xs">
        <a href="https://jaackson.com/" target="_blank" rel="noopener" class="hover:text-white/50 transition-colors">Built and Operated by William Jackson</a>
        <a href="https://www.griffith.edu.au" target="_blank" rel="noopener" class="hover:text-white/50 transition-colors">Griffith University</a>
      </div>
      <a href="<%= helpers.new_session_path %>" class="absolute -top-3 right-0 text-white/15 hover:text-white/30 transition-colors" aria-label="Staff login"><%= helpers.icon"settings", class: "w-3 h-3" %></a>
    </div>
  </div>
</footer>
